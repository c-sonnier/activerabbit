                  data-addons-target="errorsValue">0 errors/mo</span>
          </div>
          <div style="display: flex; justify-content: space-between; font-size: 11px; color: #9ca3af; margin-top: 4px;">
            <span>0</span><span>500K</span><span>1M</span>
          </div>
        </div>

        <!-- Session Replay — Slider -->
        <div style="background: #fff; border: 1px solid #e5e7eb; border-radius: 12px; padding: 20px; transition: all 0.2s;"
             data-addons-target="replayCard">
          <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 12px;">
            <div style="display: flex; align-items: center; gap: 16px;">
              <div style="width: 44px; height: 44px; border-radius: 10px; background: linear-gradient(135deg, #93c5fd, #2563eb); display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
                <svg width="20" height="20" fill="none" stroke="white" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5.25 5.653c0-.856.917-1.398 1.667-.986l11.54 6.348a1.125 1.125 0 010 1.971l-11.54 6.347a1.125 1.125 0 01-1.667-.985V5.653z"/></svg>
              </div>
              <div>
                <div style="font-size: 11px; color: #6b7280; text-transform: uppercase; letter-spacing: 0.05em; font-weight: 600;">Monthly Replays for Session Replay</div>
                <div style="font-weight: 700; color: #111827; margin-top: 2px;">Session Replay</div>
                <div style="font-size: 13px; color: #6b7280; margin-top: 2px;">A replay is a video-like reproduction of a user session including page visits, mouse movements, clicks, and scrolls. See exactly what users experienced before and after an error.</div>
                <div style="font-size: 12px; color: #2563eb; margin-top: 4px;">$14 per 5K sessions &middot; 50 sessions included</div>
              </div>
            </div>
            <div style="text-align: right; flex-shrink: 0; margin-left: 16px;">
              <span style="font-size: 20px; font-weight: 800; color: #111827;" data-addons-target="replayPrice">$0</span>
              <span style="font-size: 13px; color: #6b7280;">/mo</span>
            </div>
          </div>
          <div style="display: flex; align-items: center; gap: 12px;">
            <input type="range" min="0" max="500000" step="5000" value="0"
                   data-addons-target="replaySlider"
                   data-action="input->addons#updateReplay"
                   style="flex: 1; height: 6px; accent-color: #2563eb; cursor: pointer;">
            <span style="min-width: 90px; text-align: right; font-size: 13px; font-weight: 600; color: #2563eb; background: #eff6ff; padding: 4px 12px; border-radius: 6px;"
                  data-addons-target="replayValue">0 sessions</span>
          </div>
          <div style="display: flex; justify-content: space-between; font-size: 11px; color: #9ca3af; margin-top: 4px;">
            <span>0</span><span>250K</span><span>500K</span>
          </div>
        </div>
      </div>

      <!-- Right: Fixed Price Summary Box -->
      <div style="width: 320px; flex-shrink: 0; position: sticky; top: 24px;" data-addons-target="summaryBox">
        <div style="background: #fff; border: 1px solid #e5e7eb; border-radius: 12px; overflow: hidden; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1), 0 2px 4px -2px rgba(0,0,0,0.1);">
          <!-- Header -->
          <div style="background: linear-gradient(135deg, #4f46e5, #7c3aed); padding: 20px 24px;">
            <div style="font-size: 13px; color: rgba(255,255,255,0.7); text-transform: uppercase; letter-spacing: 0.05em; font-weight: 600;">Reserved Pricing</div>
            <div style="margin-top: 4px;">
              <span style="font-size: 32px; font-weight: 800; color: #fff;" data-addons-target="totalMonthly">$29</span>
              <span style="font-size: 14px; color: rgba(255,255,255,0.7);">/mo</span>
            </div>
          </div>
          <!-- Body -->
          <div style="padding: 20px 24px;">
            <!-- Paid Plan Tier -->
            <div style="margin-bottom: 16px;">
              <div style="font-size: 11px; color: #6b7280; text-transform: uppercase; letter-spacing: 0.05em; font-weight: 600; margin-bottom: 6px;">Paid Plan Tier</div>
              <div style="display: flex; background: #f3f4f6; border-radius: 8px; padding: 3px;">
                <button type="button" data-action="click->addons#selectTier" data-plan="team" data-addons-target="tierTeam"
                        style="flex: 1; padding: 6px 0; font-size: 13px; font-weight: 600; border-radius: 6px; border: none; cursor: pointer; background: #fff; color: #111827; box-shadow: 0 1px 2px rgba(0,0,0,0.08); transition: all 0.15s;">Team</button>
                <button type="button" data-action="click->addons#selectTier" data-plan="business" data-addons-target="tierBusiness"
                        style="flex: 1; padding: 6px 0; font-size: 13px; font-weight: 600; border-radius: 6px; border: none; cursor: pointer; background: transparent; color: #6b7280; transition: all 0.15s;">Business</button>
              </div>
            </div>

            <!-- Payment Frequency -->
            <div style="margin-bottom: 16px;">
              <div style="font-size: 11px; color: #6b7280; text-transform: uppercase; letter-spacing: 0.05em; font-weight: 600; margin-bottom: 6px;">Payment Frequency</div>
              <div style="display: flex; background: #f3f4f6; border-radius: 8px; padding: 3px;">
                <button type="button" data-action="click->addons#selectFrequency" data-frequency="monthly" data-addons-target="freqMonthly"
                        style="flex: 1; padding: 6px 0; font-size: 13px; font-weight: 600; border-radius: 6px; border: none; cursor: pointer; background: #fff; color: #111827; box-shadow: 0 1px 2px rgba(0,0,0,0.08); transition: all 0.15s;">Monthly</button>
                <button type="button" data-action="click->addons#selectFrequency" data-frequency="annual" data-addons-target="freqAnnual"
                        style="flex: 1; padding: 6px 0; font-size: 13px; font-weight: 600; border-radius: 6px; border: none; cursor: pointer; background: transparent; color: #6b7280; transition: all 0.15s;">Annual</button>
              </div>
            </div>

            <!-- Line items -->
            <div data-addons-target="itemList" style="margin-bottom: 16px;">
            </div>

            <!-- Divider + Total -->
            <div style="border-top: 2px solid #e5e7eb; padding-top: 16px;" data-addons-target="totalSection">
            </div>

            <!-- Subscribe Button -->
            <div style="margin-top: 20px;">
              <%= form_with url: checkouts_path, method: :post, local: true, data: { turbo: false, addons_target: "subscribeForm" } do %>
                <input type="hidden" name="plan" value="team" data-addons-target="formPlan">
                <input type="hidden" name="interval" value="month" data-addons-target="formInterval">
                <input type="hidden" name="ai" value="0" data-addons-target="formAi">
                <input type="hidden" name="uptime_monitors" value="0" data-addons-target="formUptime">
                <input type="hidden" name="extra_errors" value="0" data-addons-target="formErrors">
                <input type="hidden" name="session_replays" value="0" data-addons-target="formReplays">
                <button type="submit" data-action="click->addons#subscribe"
                        style="width: 100%; padding: 12px 0; background: linear-gradient(135deg, #4f46e5, #7c3aed); color: #fff; font-size: 15px; font-weight: 700; border: none; border-radius: 8px; cursor: pointer; transition: opacity 0.15s; letter-spacing: 0.01em;"
                        onmouseover="this.style.opacity='0.9'" onmouseout="this.style.opacity='1'">
                  Subscribe
                </button>
              <% end %>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Usage Limits table hidden — all features now shown in plan cards above -->
</div>
