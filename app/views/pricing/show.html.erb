<% content_for :page_title do %>
  Plans & Pricing
<% end %>

<% if @account %>
  <div class="bg-indigo-50 border border-indigo-200 rounded-lg p-4 mb-6 mx-auto" style="width: 85%">
    <div class="flex items-center justify-between mb-4">
      <div>
        <h2 class="text-lg font-semibold text-indigo-900">Current Plan: <%= @account.effective_plan_name %></h2>
        <% if @account.on_trial? %>
          <% trial_days_left = [(@account.trial_ends_at.to_date - Date.current).to_i, 0].max %>
          <p class="text-xs text-indigo-700 mt-1">
            You're on a <span class="font-semibold">14-day free trial</span> with full access.
            <strong><%= trial_days_left %> day<%= "s" unless trial_days_left == 1 %></strong> remaining.
            Subscribe to a plan to keep monitoring uninterrupted after your trial ends.
          </p>
        <% elsif @account.respond_to?(:trial_expired_without_payment?) && @account.trial_expired_without_payment? %>
          <p class="text-xs text-red-700 mt-1">
            Trial expired &mdash; you've been moved to the Free plan.
            <%= link_to "Upgrade", "#pricing-plans", class: "font-semibold text-indigo-600 hover:text-indigo-800 underline" %> to unlock higher limits.
          </p>
        <% elsif @account.on_free_plan? %>
          <p class="text-xs text-gray-600 mt-1">
            You're on the Free plan.
            <%= link_to "Upgrade", "#pricing-plans", class: "font-semibold text-indigo-600 hover:text-indigo-800 underline" %> to unlock more features.
          </p>
        <% end %>
        <% if @next_payment_date %>
          <p class="text-sm text-indigo-700">
            Next payment on <%= @next_payment_date %>
          </p>
        <% end %>
      </div>
      <div class="flex space-x-2">
        <%= link_to usage_path, class: "inline-flex items-center px-3 py-1.5 text-sm font-medium rounded-md text-purple-700 bg-purple-100 hover:bg-purple-200" do %>
          <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 8v8m-4-5v5m-4-2v2m-2 4h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
          View Your Usage & Quotas
        <% end %>
        <% if @account.active_subscription? %>
          <%= button_to "View Invoices", billing_portal_index_path,
                method: :post,
                data: { turbo: false },
                form: { target: "_blank" },
                class: "inline-flex items-center px-3 py-1.5 border border-transparent text-xs font-medium rounded-md shadow-sm text-white bg-indigo-600 hover:bg-indigo-700" %>
          <%= button_to "Manage Plan", billing_portal_index_path,
                method: :post,
                data: { turbo: false },
                form: { target: "_blank" },
                class: "inline-flex items-center px-3 py-1.5 border border-indigo-700 text-xs font-medium rounded-md shadow-sm text-indigo-700 bg-white hover:bg-indigo-50" %>
        <% end %>
      </div>
    </div>
  </div>
<% end %>

