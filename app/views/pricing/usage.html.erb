<% content_for :page_title do %>
  Usage & Quotas
<% end %>

<% if @account %>
  <%
    needs_payment = @account.needs_payment_method_warning? || @account.trial_expired_without_payment?
    plan_display = @account.effective_plan_name
  %>
  <div class="<%= needs_payment ? 'bg-red-50 border-red-300' : 'bg-indigo-50 border-indigo-200' %> border rounded-lg p-4 mb-6 mx-auto w-full lg:w-[85%]">
    <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 mb-4">
      <div>
        <div class="flex flex-wrap items-center gap-2">
          <h2 class="text-lg font-semibold <%= needs_payment ? 'text-red-900' : 'text-indigo-900' %>">
            Current Plan: <%= @account.effective_plan_name %>
            <% if @account.on_trial? %>
              <% trial_days = [(@account.trial_ends_at.to_date - Date.current).to_i, 0].max %>
              <span class="ml-2 text-sm font-medium text-indigo-600"><%= trial_days %> <%= trial_days == 1 ? 'day' : 'days' %> left</span>
            <% end %>
          </h2>
          <% if @account.trial_expired_without_payment? %>
            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-800">
              Free plan
            </span>
          <% elsif @account.on_trial? %>
            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-indigo-100 text-indigo-800">
              Trial
            </span>
          <% end %>
        </div>
        <% if needs_payment %>
          <p class="text-sm text-red-700 mt-1">
            <% if @account.trial_expired_without_payment? %>
              Your trial ended. You're now on the Free plan. Choose a plan to unlock higher limits.
            <% else %>
              Subscribe to a plan to keep monitoring uninterrupted after your trial ends.
            <% end %>
          </p>
        <% elsif @next_payment_date %>
          <p class="text-sm text-indigo-700">
            Next payment on <%= @next_payment_date %>
          </p>
        <% end %>
      </div>
      <div class="flex flex-wrap gap-2">
        <%= link_to "Choose Plan", plan_path, class: "inline-flex items-center px-3 py-1.5 border border-transparent text-xs font-medium rounded-md shadow-sm text-white #{needs_payment ? 'bg-red-600 hover:bg-red-700' : 'bg-indigo-600 hover:bg-indigo-700'}" %>
        <% if @account.active_subscription? %>
          <%= button_to "View Invoices", billing_portal_index_path,
                method: :post, data: { turbo: false }, form: { target: "_blank" }, class: "inline-flex items-center px-3 py-1.5 border border-transparent text-xs font-medium rounded-md shadow-sm text-white bg-indigo-600 hover:bg-indigo-700" %>
          <%= button_to "Manage Plan", billing_portal_index_path,
                method: :post, data: { turbo: false }, form: { target: "_blank" }, class: "inline-flex items-center px-3 py-1.5 border border-indigo-700 text-xs font-medium rounded-md shadow-sm text-indigo-700 bg-white hover:bg-indigo-50" %>
        <% end %>
      </div>
    </div>
  </div>
<% end %>

<div class="space-y-8 mx-auto w-full lg:w-[85%]">
  <!-- Current Usage Box -->
  <% if @account %>
    <% first_project = @account.projects.order(:id).first %>
    <div class="bg-gradient-to-br from-indigo-50 to-purple-50 rounded-2xl p-8 border-2 border-indigo-200 shadow-lg mb-12">
      <div class="text-center mb-6">
        <h2 class="text-3xl font-bold text-gray-900 mb-2">Current Plan: <span class="text-indigo-600"><%= @account.effective_plan_name %></span></h2>
        <p class="text-sm text-gray-500 mt-1">
          Billing Period: <%= (@account.event_usage_period_start || Time.current.beginning_of_month).strftime('%b %d') %> - <%= (@account.event_usage_period_end || Time.current.end_of_month).strftime('%b %d, %Y') %>
        </p>
        <p class="text-xs text-gray-400 mt-1">
          <% if @account.usage_cached_at %>
            Last updated: <%= time_ago_in_words(@account.usage_cached_at) %> ago •
          <% end %>
          Data updates every hour
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <!-- Data Retention -->
        <div class="bg-white rounded-xl p-6 shadow-md hover:shadow-xl transition-shadow border-l-4 border-amber-500">
          <div class="flex items-center justify-between mb-3">
            <div class="flex items-center gap-2">
              <svg class="w-6 h-6 text-amber-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
              <h3 class="text-lg font-semibold text-gray-900">Data Retention</h3>
            </div>
            <span class="text-2xl font-bold text-amber-600"><%= @data_retention_days %> days</span>
          </div>
          <div class="space-y-2">
            <p class="text-xs text-gray-500">
              Error and performance data older than <%= @data_retention_days %> days is automatically removed.
            </p>
            <% if @is_free_plan %>
              <div class="flex items-center gap-2 text-xs text-gray-400 mt-2">
                <svg class="w-4 h-4 text-amber-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
                Team &amp; Business: 31 days retention
              </div>
              <a href="<%= plan_path %>" class="inline-flex items-center px-3 py-1.5 text-xs font-semibold text-white bg-gradient-to-r from-indigo-600 to-violet-600 rounded-md shadow hover:from-indigo-700 hover:to-violet-700 transition-all mt-1">
                Upgrade for more
              </a>
            <% end %>
            <div class="mt-2">
              <%= link_to errors_path, class: "text-xs text-indigo-600 hover:text-indigo-800 font-medium" do %>
                View errors &rarr;
              <% end %>
            </div>
          </div>
        </div>

        <!-- AI Summaries -->
        <% if @is_free_plan %>
          <div class="bg-white rounded-xl p-6 shadow-md hover:shadow-xl transition-shadow border-l-4 border-orange-400">
            <div class="flex items-center justify-between mb-3">
              <h3 class="text-lg font-semibold text-gray-900">AI Summaries</h3>
              <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-bold bg-orange-100 text-orange-700">NOT AVAILABLE</span>
            </div>
            <div class="space-y-3">
              <p class="text-sm text-gray-500">AI-powered error analysis is not included in the Free plan.</p>
              <div class="flex items-center gap-2 text-xs text-gray-500">
                <svg class="w-4 h-4 text-purple-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/>
                </svg>
                Team plan: $29/mo &bull; Business: $80/mo
              </div>
              <a href="<%= plan_path %>" class="inline-flex items-center px-3 py-1.5 text-xs font-semibold text-white bg-gradient-to-r from-indigo-600 to-violet-600 rounded-md shadow hover:from-indigo-700 hover:to-violet-700 transition-all">
                Upgrade to unlock
              </a>
            </div>
            <div class="mt-2">
              <%= link_to errors_path, class: "text-xs text-indigo-600 hover:text-indigo-800 font-medium" do %>
                View issues &rarr;
              <% end %>
            </div>
          </div>
        <% else %>
          <div class="bg-white rounded-xl p-6 shadow-md hover:shadow-xl transition-shadow border-l-4 border-purple-500">
            <div class="flex items-center justify-between mb-3">
              <h3 class="text-lg font-semibold text-gray-900">AI Error Analysis</h3>
              <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-bold bg-purple-100 text-purple-700">UNLIMITED</span>
            </div>
            <div class="space-y-2">
              <div class="flex justify-between text-sm">
                <span class="text-gray-600">Used (billing period):</span>
                <span class="font-bold text-gray-900"><%= @ai_summaries_used %></span>
              </div>
              <div class="flex justify-between text-sm">
                <span class="text-gray-600">Quota:</span>
                <span class="font-medium text-purple-600">Unlimited</span>
              </div>
              <div class="flex justify-between text-xs text-gray-500">
                <span>Last 30 days:</span>
                <span><%= number_with_delimiter(@ai_summaries_last_30_days) %></span>
              </div>
              <div class="mt-2">
                <%= link_to errors_path, class: "text-xs text-indigo-600 hover:text-indigo-800 font-medium" do %>
                  View issues &rarr;
                <% end %>
              </div>
            </div>
          </div>
        <% end %>

        <!-- Pull Requests -->
        <% if @is_free_plan %>
          <div class="bg-white rounded-xl p-6 shadow-md hover:shadow-xl transition-shadow border-l-4 border-orange-400">
            <div class="flex items-center justify-between mb-3">
              <h3 class="text-lg font-semibold text-gray-900">Pull Requests</h3>
              <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-bold bg-orange-100 text-orange-700">NOT AVAILABLE</span>
            </div>
            <div class="space-y-3">
              <p class="text-sm text-gray-500">AI-generated pull requests are not included in the Free plan.</p>
              <div class="flex items-center gap-2 text-xs text-gray-500">
                <svg class="w-4 h-4 text-pink-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4"/>
                </svg>
                Team plan: $29/mo &bull; Business: $80/mo
              </div>
              <a href="<%= plan_path %>" class="inline-flex items-center px-3 py-1.5 text-xs font-semibold text-white bg-gradient-to-r from-indigo-600 to-violet-600 rounded-md shadow hover:from-indigo-700 hover:to-violet-700 transition-all">
                Upgrade to unlock
              </a>
            </div>
            <div class="mt-2">
              <%= link_to errors_path, class: "text-xs text-indigo-600 hover:text-indigo-800 font-medium" do %>
                View issues &rarr;
              <% end %>
            </div>
          </div>
        <% else %>
          <% pr_pct = @account.usage_percentage(:pull_requests) %>
          <% pr_over = pr_pct >= 100 %>
          <div class="bg-white rounded-xl p-6 shadow-md hover:shadow-xl transition-shadow border-l-4 <%= pr_over ? 'border-red-500 ring-2 ring-red-200' : 'border-pink-500' %>">
            <div class="flex items-center justify-between mb-3">
              <h3 class="text-lg font-semibold text-gray-900">Pull Requests</h3>
              <% if pr_over %>
                <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-bold bg-red-100 text-red-800">OVER LIMIT</span>
              <% else %>
                <svg class="w-8 h-8 text-pink-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4"/>
                </svg>
              <% end %>
            </div>
            <div class="space-y-2">
              <div class="flex justify-between text-sm">
                <span class="text-gray-600">Used (billing period):</span>
                <span class="font-bold <%= pr_over ? 'text-red-600' : 'text-gray-900' %>"><%= @pull_requests_used %></span>
              </div>
              <div class="flex justify-between text-sm">
                <span class="text-gray-600">Quota:</span>
                <span class="font-medium text-gray-700"><%= @pull_requests_quota %></span>
              </div>
              <div class="flex justify-between text-xs text-gray-500">
                <span>Last 30 days:</span>
                <span><%= number_with_delimiter(@pull_requests_last_30_days) %></span>
              </div>
              <div class="w-full bg-gray-200 rounded-full h-3 mt-2">
                <div class="<%= pr_over ? 'bg-red-500' : 'bg-pink-500' %> h-3 rounded-full transition-all" style="width: <%= [pr_pct, 100].min %>%"></div>
              </div>
              <div class="text-right text-sm font-bold <%= pr_over ? 'text-red-600' : (pr_pct >= 90 ? 'text-orange-500' : pr_pct >= 80 ? 'text-yellow-500' : 'text-green-500') %>">
                <%= pr_pct.round(1) %>%
              </div>
              <div class="mt-2">
                <%= link_to errors_path, class: "text-xs text-indigo-600 hover:text-indigo-800 font-medium" do %>
                  View issues &rarr;
                <% end %>
              </div>
            </div>
          </div>
        <% end %>

        <!-- Session Replay -->
        <% if @is_free_plan %>
          <div class="bg-white rounded-xl p-6 shadow-md hover:shadow-xl transition-shadow border-l-4 border-orange-400">
            <div class="flex items-center justify-between mb-3">
              <h3 class="text-lg font-semibold text-gray-900">Session Replay</h3>
              <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-bold bg-orange-100 text-orange-700">NOT AVAILABLE</span>
            </div>
            <div class="space-y-3">
              <p class="text-sm text-gray-500">Session replay is not included in the Free plan.</p>
              <div class="flex items-center gap-2 text-xs text-gray-500">
                <svg class="w-4 h-4 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5.25 5.653c0-.856.917-1.398 1.667-.986l11.54 6.348a1.125 1.125 0 010 1.971l-11.54 6.347a1.125 1.125 0 01-1.667-.985V5.653z"/>
                </svg>
                Team: 10 replays &bull; Business: 10 replays
              </div>
              <a href="<%= plan_path %>" class="inline-flex items-center px-3 py-1.5 text-xs font-semibold text-white bg-gradient-to-r from-indigo-600 to-violet-600 rounded-md shadow hover:from-indigo-700 hover:to-violet-700 transition-all">
                Upgrade to unlock
              </a>
            </div>
          </div>
        <% else %>
          <%
            replay_pct = @session_replays_quota.to_i > 0 ? ((@session_replays_used.to_f / @session_replays_quota) * 100).round(1) : 100
            replay_over = replay_pct >= 100
          %>
          <div class="bg-white rounded-xl p-6 shadow-md hover:shadow-xl transition-shadow border-l-4 <%= replay_over ? 'border-red-500 ring-2 ring-red-200' : 'border-blue-500' %>">
            <div class="flex items-center justify-between mb-3">
              <div class="flex items-center gap-2">
                <svg class="w-6 h-6 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5.25 5.653c0-.856.917-1.398 1.667-.986l11.54 6.348a1.125 1.125 0 010 1.971l-11.54 6.347a1.125 1.125 0 01-1.667-.985V5.653z"/>
                </svg>
                <h3 class="text-lg font-semibold text-gray-900">Session Replay</h3>
              </div>
              <% if replay_over %>
                <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-bold bg-red-100 text-red-800">LIMIT REACHED</span>
              <% end %>
            </div>
            <div class="space-y-2">
              <div class="flex justify-between text-sm">
                <span class="text-gray-600">Replays used:</span>
                <span class="font-bold text-gray-900"><%= number_with_delimiter(@session_replays_used) %></span>
              </div>
              <div class="flex justify-between text-sm">
                <span class="text-gray-600">Quota:</span>
                <span class="font-medium text-gray-700"><%= number_with_delimiter(@session_replays_quota) %></span>
              </div>
              <div class="flex justify-between text-sm">
                <span class="text-gray-600">Remaining:</span>
                <span class="font-medium <%= @session_replays_remaining.to_i <= 0 ? 'text-red-600' : 'text-blue-600' %>"><%= number_with_delimiter([@session_replays_remaining, 0].max) %></span>
              </div>
              <div class="w-full bg-gray-200 rounded-full h-3 mt-3">
                <div class="<%= replay_over ? 'bg-red-500' : (replay_pct >= 80 ? 'bg-yellow-500' : 'bg-blue-500') %> h-3 rounded-full transition-all" style="width: <%= [replay_pct, 100].min %>%"></div>
              </div>
              <div class="text-right text-sm font-bold <%= replay_over ? 'text-red-600' : (replay_pct >= 90 ? 'text-orange-500' : replay_pct >= 80 ? 'text-yellow-500' : 'text-blue-600') %>">
                <%= replay_pct %>%
              </div>
              <% if first_project %>
                <div class="mt-2">
                  <%= link_to project_replays_path(first_project.slug), class: "text-xs text-indigo-600 hover:text-indigo-800 font-medium" do %>
                    View replays &rarr;
                  <% end %>
                </div>
              <% end %>
            </div>
          </div>
        <% end %>
        <!-- Uptime Monitoring -->
        <% if @is_free_plan %>
          <div class="bg-white rounded-xl p-6 shadow-md hover:shadow-xl transition-shadow border-l-4 border-orange-400">
            <div class="flex items-center justify-between mb-3">
              <h3 class="text-lg font-semibold text-gray-900">Uptime Monitoring</h3>
              <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-bold bg-orange-100 text-orange-700">NOT AVAILABLE</span>
            </div>
            <div class="space-y-3">
              <p class="text-sm text-gray-500">Uptime monitoring is not included in the Free plan.</p>
              <div class="flex items-center gap-2 text-xs text-gray-500">
                <svg class="w-4 h-4 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
                </svg>
                Team: 3 monitors (uptime + cron) &bull; Business: 5 monitors
              </div>
              <a href="<%= plan_path %>" class="inline-flex items-center px-3 py-1.5 text-xs font-semibold text-white bg-gradient-to-r from-indigo-600 to-violet-600 rounded-md shadow hover:from-indigo-700 hover:to-violet-700 transition-all">
                Upgrade to unlock
              </a>
            </div>
            <div class="mt-2">
              <%= link_to uptime_index_path, class: "text-xs text-indigo-600 hover:text-indigo-800 font-medium" do %>
                View monitors &rarr;
              <% end %>
            </div>
          </div>
        <% else %>
          <%
            uptime_pct = @uptime_monitors_quota.to_i > 0 ? ((@uptime_monitors_used.to_f / @uptime_monitors_quota) * 100).round(1) : 100
            uptime_over = uptime_pct >= 100
          %>
          <div class="bg-white rounded-xl p-6 shadow-md hover:shadow-xl transition-shadow border-l-4 <%= uptime_over ? 'border-red-500 ring-2 ring-red-200' : 'border-emerald-500' %>">
            <div class="flex items-center justify-between mb-3">
              <div class="flex items-center gap-2">
                <svg class="w-6 h-6 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
                </svg>
                <h3 class="text-lg font-semibold text-gray-900">Monitors</h3>
              </div>
              <% if uptime_over %>
                <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-bold bg-red-100 text-red-800">LIMIT REACHED</span>
              <% end %>
            </div>
            <div class="space-y-2">
              <div class="flex justify-between text-sm">
                <span class="text-gray-600">Active monitors (uptime + cron):</span>
                <span class="font-bold <%= uptime_over ? 'text-red-600' : 'text-gray-900' %>"><%= @uptime_monitors_used %></span>
              </div>
              <div class="flex justify-between text-sm">
                <span class="text-gray-600">Quota:</span>
                <span class="font-medium text-gray-700"><%= @uptime_monitors_quota %></span>
              </div>
              <div class="flex justify-between text-sm">
                <span class="text-gray-600">Remaining:</span>
                <span class="font-medium <%= @uptime_monitors_remaining.to_i > 0 ? 'text-green-600' : 'text-red-600' %>"><%= [@uptime_monitors_remaining, 0].max %></span>
              </div>
              <div class="w-full bg-gray-200 rounded-full h-3 mt-2">
                <div class="<%= uptime_over ? 'bg-red-500' : 'bg-emerald-500' %> h-3 rounded-full transition-all" style="width: <%= [uptime_pct, 100].min %>%"></div>
              </div>
              <div class="text-right text-sm font-bold <%= uptime_over ? 'text-red-600' : (uptime_pct >= 90 ? 'text-orange-500' : uptime_pct >= 80 ? 'text-yellow-500' : 'text-green-500') %>">
                <%= uptime_pct %>%
              </div>
              <div class="flex items-center gap-2 text-xs text-gray-500 mt-1">
                <svg class="w-3.5 h-3.5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
                Check data retained for <%= @data_retention_days %> days
              </div>
              <div class="flex items-center justify-between mt-2">
                <%= link_to uptime_index_path, class: "text-xs text-indigo-600 hover:text-indigo-800 font-medium" do %>
                  View monitors &rarr;
                <% end %>
                <% if uptime_over %>
                  <a href="<%= plan_path %>" class="inline-flex items-center px-3 py-1.5 text-xs font-semibold text-white bg-gradient-to-r from-indigo-600 to-violet-600 rounded-md shadow hover:from-indigo-700 hover:to-violet-700 transition-all">
                    Upgrade for more
                  </a>
                <% end %>
              </div>
            </div>
          </div>
        <% end %>

        <!-- Requests Total (last 30 days, all sources incl. performance) -->
        <div class="bg-white rounded-xl p-6 shadow-md hover:shadow-xl transition-shadow border-l-4 border-gray-500">
          <div class="flex items-center justify-between mb-3">
            <h3 class="text-lg font-semibold text-gray-900">Requests Total</h3>
            <svg class="w-8 h-8 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17v2a2 2 0 002 2h2a2 2 0 002-2v-2m-9-4h10M5 9h14M5 5h14"/>
            </svg>
          </div>
          <div class="space-y-2">
            <div class="flex justify-between text-sm">
              <span class="text-gray-600">Requests (last 30 days):</span>
              <span class="font-bold text-gray-900"><%= number_with_delimiter(@requests_total_last_30_days) %></span>
            </div>
            <div class="mt-2 flex flex-wrap gap-x-4 gap-y-1">
              <%= link_to performance_path, class: "text-xs text-indigo-600 hover:text-indigo-800 font-medium" do %>
                View performance &rarr;
              <% end %>
              <%= link_to errors_path, class: "text-xs text-indigo-600 hover:text-indigo-800 font-medium" do %>
                View errors &rarr;
              <% end %>
            </div>
          </div>
        </div>
      </div>

      <!-- Plan Features Section -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mt-8">
        <!-- Error Tracking -->
        <% events_pct = @account.usage_percentage(:events) %>
        <% events_over = events_pct >= 100 %>
        <div class="bg-white rounded-xl p-6 shadow-md hover:shadow-xl transition-shadow border-l-4 <%= events_over ? 'border-red-500 ring-2 ring-red-200' : 'border-indigo-500' %>">
          <div class="flex items-center justify-between mb-3">
            <h3 class="text-lg font-semibold text-gray-900">Error Tracking</h3>
            <% if events_over %>
              <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-bold bg-red-100 text-red-800">OVER LIMIT</span>
            <% else %>
              <svg class="w-8 h-8 text-indigo-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
              </svg>
            <% end %>
          </div>
          <div class="space-y-2">
            <div class="flex justify-between text-sm">
              <span class="text-gray-600">Used (billing period):</span>
              <span class="font-bold <%= events_over ? 'text-red-600' : 'text-gray-900' %>"><%= number_with_delimiter(@events_used) %></span>
            </div>
            <div class="flex justify-between text-sm">
              <span class="text-gray-600">Quota:</span>
              <span class="font-medium text-gray-700"><%= number_with_delimiter(@event_quota) %></span>
            </div>
            <div class="flex justify-between text-xs text-gray-500">
              <span>Last 30 days:</span>
              <span><%= number_with_delimiter(@events_last_30_days) %></span>
            </div>
            <div class="w-full bg-gray-200 rounded-full h-3 mt-2">
              <div class="<%= events_over ? 'bg-red-500' : 'bg-indigo-500' %> h-3 rounded-full transition-all" style="width: <%= [events_pct, 100].min %>%"></div>
            </div>
            <div class="text-right text-sm font-bold <%= events_over ? 'text-red-600' : (events_pct >= 90 ? 'text-orange-500' : events_pct >= 80 ? 'text-yellow-500' : 'text-green-500') %>">
              <%= events_pct.round(1) %>%
            </div>
            <% if @is_free_plan %>
              <% if events_over %>
                <p class="text-xs text-red-600 font-medium mt-1">Hard cap reached — new events are paused until your billing period resets.</p>
              <% else %>
                <p class="text-xs text-gray-400 mt-1">Hard-capped at <%= number_with_delimiter(@event_quota) %>/mo — no overage fees.</p>
              <% end %>
              <div class="flex items-center gap-2 text-xs text-gray-400 mt-2">
                <svg class="w-4 h-4 text-indigo-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
                </svg>
                Team: 50,000/mo &bull; Business: 100,000/mo
              </div>
              <a href="<%= plan_path %>" class="inline-flex items-center px-3 py-1.5 text-xs font-semibold text-white bg-gradient-to-r from-indigo-600 to-violet-600 rounded-md shadow hover:from-indigo-700 hover:to-violet-700 transition-all mt-1">
                Upgrade for more
              </a>
            <% end %>
            <div class="mt-2">
              <%= link_to errors_path, class: "text-xs text-indigo-600 hover:text-indigo-800 font-medium" do %>
                View errors &rarr;
              <% end %>
            </div>
          </div>
        </div>

        <!-- Users -->
        <div class="bg-white rounded-xl p-6 shadow-md hover:shadow-xl transition-shadow border-l-4 border-cyan-500">
          <div class="flex items-center justify-between mb-3">
            <h3 class="text-lg font-semibold text-gray-900">Users</h3>
            <svg class="w-8 h-8 text-cyan-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
          </div>
          <div class="space-y-2">
            <div class="flex justify-between text-sm">
              <span class="text-gray-600">Current users:</span>
              <span class="font-bold text-gray-900"><%= @users_used %></span>
            </div>
            <div class="flex justify-between text-sm">
              <span class="text-gray-600">Limit:</span>
              <span class="font-medium text-gray-700"><%= @users_quota ? @users_quota : "Unlimited" %></span>
            </div>
            <% if @is_free_plan %>
              <div class="flex items-center gap-2 text-xs text-gray-400 mt-2">
                <svg class="w-4 h-4 text-cyan-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/>
                </svg>
                Team &amp; Business: Unlimited users
              </div>
              <a href="<%= plan_path %>" class="inline-flex items-center px-3 py-1.5 text-xs font-semibold text-white bg-gradient-to-r from-indigo-600 to-violet-600 rounded-md shadow hover:from-indigo-700 hover:to-violet-700 transition-all mt-1">
                Upgrade for more
              </a>
            <% end %>
            <div class="mt-2">
              <%= link_to users_path, class: "text-xs text-indigo-600 hover:text-indigo-800 font-medium" do %>
                Manage team &rarr;
              <% end %>
            </div>
          </div>
        </div>

        <!-- Logs (structured log storage; quota shared across plans) -->
        <%
          log_bytes_used = @account.log_bytes_used
          log_bytes_quota = @account.log_bytes_quota
          log_storage_pct = log_bytes_quota.positive? ? (log_bytes_used.to_f / log_bytes_quota * 100).round(1) : 0.0
          log_storage_over = @account.log_quota_exceeded?
          log_entries_period = @account.cached_log_entries_used.to_i
        %>
        <div class="bg-white rounded-xl p-6 shadow-md hover:shadow-xl transition-shadow border-l-4 <%= log_storage_over ? 'border-red-500 ring-2 ring-red-200' : 'border-slate-500' %>">
          <div class="flex items-center justify-between mb-3">
            <h3 class="text-lg font-semibold text-gray-900">Logs</h3>
            <% if log_storage_over %>
              <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-bold bg-red-100 text-red-800">STORAGE FULL</span>
            <% else %>
              <svg class="w-8 h-8 text-slate-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
              </svg>
            <% end %>
          </div>
          <div class="space-y-2">
            <div class="flex justify-between text-sm">
              <span class="text-gray-600">Storage used:</span>
              <span class="font-bold <%= log_storage_over ? 'text-red-600' : 'text-gray-900' %>"><%= number_to_human_size(log_bytes_used) %></span>
            </div>
            <div class="flex justify-between text-sm">
              <span class="text-gray-600">Quota:</span>
              <span class="font-medium text-gray-700"><%= number_to_human_size(log_bytes_quota) %></span>
            </div>
            <div class="flex justify-between text-xs text-gray-500">
              <span>Entries (billing period):</span>
              <span><%= number_with_delimiter(log_entries_period) %></span>
            </div>
            <div class="w-full bg-gray-200 rounded-full h-3 mt-2">
              <div class="<%= log_storage_over ? 'bg-red-500' : 'bg-slate-500' %> h-3 rounded-full transition-all" style="width: <%= [log_storage_pct, 100].min %>%"></div>
            </div>
            <div class="text-right text-sm font-bold <%= log_storage_over ? 'text-red-600' : (log_storage_pct >= 90 ? 'text-orange-500' : log_storage_pct >= 80 ? 'text-yellow-500' : 'text-slate-600') %>">
              <%= log_storage_pct %>%
            </div>
            <% if log_storage_over %>
              <p class="text-xs text-red-600 font-medium mt-1">New log ingestion is paused until you free space or contact support for a higher limit.</p>
            <% else %>
              <p class="text-xs text-gray-400 mt-1">Sentry-style structured logs; PII in params/context is scrubbed.</p>
            <% end %>
            <div class="mt-2">
              <%= link_to logs_path, class: "text-xs text-indigo-600 hover:text-indigo-800 font-medium" do %>
                View logs &rarr;
              <% end %>
            </div>
          </div>
        </div>
      </div>

      <!-- Status Message -->
      <div class="mt-6 text-center">
        <% if @account.resources_with_warnings.any? %>
          <% exceeded_resources = @account.resources_with_warnings.select { |w| w[:level] == :exceeded } %>
          <% if exceeded_resources.any? %>
            <div class="inline-flex items-center px-4 py-2 rounded-full bg-red-100 text-red-800 text-sm font-medium mb-2">
              <svg class="w-4 h-4 mr-2" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/>
              </svg>
              <% resource_names = exceeded_resources.map { |r| r[:name] }.join(", ") %>
              <%= resource_names %>: <%= exceeded_resources.first[:percentage].round %>% used - <%= link_to "View plans", plan_path, class: "underline font-semibold" %>
            </div>
          <% end %>

          <% warning_resources = @account.resources_with_warnings.select { |w| w[:level] != :exceeded } %>
          <% warning_resources.each do |warning| %>
            <div class="inline-flex items-center px-4 py-2 rounded-full <%= warning[:level] == :danger ? 'bg-orange-100 text-orange-800' : 'bg-yellow-100 text-yellow-800' %> text-sm font-medium mx-2 mb-2">
              <svg class="w-4 h-4 mr-2" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/>
              </svg>
              <%= warning[:name] %>: <%= warning[:percentage].round %>% used
            </div>
          <% end %>
        <% else %>
          <p class="text-green-600 font-medium">✅ All resources within quota</p>
        <% end %>
      </div>
    </div>
  <% end %>
</div>

