<!DOCTYPE html>
<html>
  <head>
    <title>ActiveRabbit - <%= yield(:title) || "Authentication" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="min-h-dvh bg-black antialiased">
    <!-- Background glow (top + bottom light bloom) -->
    <div class="fixed inset-0 pointer-events-none select-none" style="background:
      radial-gradient(ellipse 40% 30% at 50% 0%, rgba(255, 255, 255, 0.18) 0%, transparent 50%),
      radial-gradient(ellipse 70% 50% at 50% 0%, rgba(255, 255, 255, 0.1) 0%, transparent 45%),
      radial-gradient(ellipse 100% 70% at 50% 0%, rgba(200, 200, 220, 0.08) 0%, transparent 55%),
      radial-gradient(circle at 50% 25%, rgba(255, 255, 255, 0.05) 0%, transparent 65%),
      radial-gradient(ellipse 120% 40% at 50% 5%, rgba(180, 180, 210, 0.06) 0%, transparent 60%),
      radial-gradient(ellipse 40% 25% at 50% 100%, rgba(255, 255, 255, 0.12) 0%, transparent 50%),
      radial-gradient(ellipse 70% 40% at 50% 100%, rgba(255, 255, 255, 0.07) 0%, transparent 45%),
      radial-gradient(ellipse 100% 50% at 50% 100%, rgba(200, 200, 220, 0.05) 0%, transparent 55%)
    "></div>

    <div class="relative min-h-dvh flex flex-col justify-center px-4 py-12 sm:px-6 lg:px-8">
      <!-- Header -->
      <div class="sm:mx-auto sm:w-full sm:max-w-md">
        <div class="flex justify-center">
          <%= render "shared/brand", href: root_path, size: 40, text_class: "text-2xl font-bold", variant: "admin" %>
        </div>

        <h2 class="mt-8 text-center text-2xl font-medium tracking-tight text-white">
          <%= yield(:page_title) %>
        </h2>
        <% if content_for?(:page_subtitle) %>
          <p class="mt-2 text-center text-sm text-gray-400">
            <%= yield(:page_subtitle) %>
          </p>
        <% end %>
      </div>

      <!-- Form Container -->
      <div class="mt-8 sm:mx-auto sm:w-full sm:max-w-md">
        <!-- Flash Messages -->
        <% if notice %>
          <div class="mb-6 rounded-xl bg-green-950/50 p-4 border border-green-800">
            <div class="flex">
              <div class="flex-shrink-0">
                <svg class="h-5 w-5 text-green-400" viewBox="0 0 20 20" fill="currentColor">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                </svg>
              </div>
              <div class="ml-3">
                <p class="text-sm font-medium text-green-400"><%= notice %></p>
              </div>
            </div>
          </div>
        <% end %>

        <% if alert %>
          <div class="mb-6 rounded-xl bg-red-950/50 p-4 border border-red-800">
            <div class="flex">
              <div class="flex-shrink-0">
                <svg class="h-5 w-5 text-red-400" viewBox="0 0 20 20" fill="currentColor">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" />
                </svg>
              </div>
              <div class="ml-3">
                <p class="text-sm font-medium text-red-400"><%= alert %></p>
              </div>
            </div>
          </div>
        <% end %>

        <%= yield %>

        <!-- Footer -->
        <div class="mt-8 text-center">
          <p class="text-xs text-gray-600">
            &copy; <%= Date.current.year %> ActiveRabbit
          </p>
        </div>
      </div>
    </div>
  </body>
</html>
