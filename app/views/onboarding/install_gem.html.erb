<% content_for :page_title do %>
  Install ActiveRabbit Gem
<% end %>

<% non_rails_stack = @project.respond_to?(:tech_stack) && @project.tech_stack.present? && @project.tech_stack != 'rails' %>

<% if non_rails_stack %>
  <div class="max-w-3xl mx-auto mt-12">
    <div class="bg-yellow-50 border border-yellow-200 rounded-lg p-6 shadow-sm">
      <div class="flex items-start">
        <div class="flex-shrink-0 mr-4">
          <span class="text-yellow-500 text-3xl leading-none">⚠️</span>
        </div>
        <div>
          <h1 class="text-2xl font-bold text-yellow-900 mb-2">Stack support coming soon</h1>
          <p class="text-sm text-yellow-800 mb-3">
            ActiveRabbit fully supports Ruby on Rails today. We are working on native support for <strong><%= @project.tech_stack.to_s.titleize %></strong>.
          </p>
          <p class="text-sm text-yellow-800 mb-3">
            We will email <strong><%= current_user.email %></strong> as soon as <%= @project.tech_stack.to_s.titleize %> support is ready.
          </p>
          <p class="text-sm text-yellow-800">
            Want early access or to share requirements? Contact us at
            <a href="mailto:support@activerabbit.ai" class="underline text-yellow-900">support@activerabbit.ai</a>.
          </p>
        </div>
      </div>
    </div>
  </div>
<% else %>
<!-- Page Header -->
<div class="mb-8">
  <div>
    <h1 class="text-2xl font-bold text-gray-900">Set Up ActiveRabbit</h1>
    <p class="text-gray-600 mt-1">
      <% if current_account.projects.count > 1 %>
        Add monitoring for "<%= @project.name %>" to your application
      <% else %>
        Add monitoring to your application
      <% end %>
    </p>
  </div>

  <!-- Error Messages -->
  <% if flash[:alert] %>
    <div class="mt-4 bg-red-50 border border-red-200 rounded-lg p-4">
      <div class="flex">
        <div class="flex-shrink-0">
          <span class="text-red-500 text-xl">❌</span>
        </div>
        <div class="ml-4">
          <h3 class="text-sm font-medium text-red-800 mb-2">Verification Failed</h3>
          <p class="text-sm text-red-700 mb-3"><%= flash[:alert] %></p>

          <% if flash[:suggestions] %>
            <div class="text-sm text-red-700">
              <p class="font-medium mb-2">Troubleshooting suggestions:</p>
              <ul class="list-disc pl-5 space-y-1">
                <% flash[:suggestions].each do |suggestion| %>
                  <li><%= suggestion %></li>
                <% end %>
              </ul>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  <% end %>
</div>

<!-- Tabs -->
<div class="mb-6 border-b border-gray-200">
  <nav class="flex space-x-8" id="setup-tabs">
    <button onclick="switchTab('errors')"
            id="tab-errors"
            class="setup-tab pb-3 px-1 border-b-2 border-purple-500 text-purple-600 font-medium text-sm whitespace-nowrap">
      Error Tracking
    </button>
    <button onclick="switchTab('logs')"
            id="tab-logs"
            class="setup-tab pb-3 px-1 border-b-2 border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300 font-medium text-sm whitespace-nowrap">
      Log Management
    </button>
  </nav>
</div>

<!-- ============================================ -->
<!-- TAB: Error Tracking                          -->
<!-- ============================================ -->
<div id="panel-errors" class="tab-panel">
<div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
  <!-- Installation Instructions -->
  <div class="lg:col-span-2">
    <div class="bg-white rounded-lg shadow p-6">
      <div class="flex items-center mb-6">
        <span class="inline-flex items-center justify-center h-10 w-10 rounded-full bg-purple-100 text-purple-600 text-lg mr-4">
          💎
        </span>
        <h2 class="text-lg font-medium text-gray-900">Step 1: Install the Gem</h2>
      </div>

      <p class="text-gray-600 mb-4">Add the ActiveRabbit gem to your Rails application's Gemfile:</p>

      <!-- Gemfile Code -->
      <div class="bg-gray-900 rounded-lg p-4 mb-6">
        <div class="flex items-center justify-between mb-2">
          <span class="text-gray-400 text-sm">Gemfile</span>
          <button onclick="copyToClipboard('gemfile-code')" class="text-gray-400 hover:text-white text-sm">
            📋 Copy
          </button>
        </div>
        <pre id="gemfile-code" class="text-green-400 text-sm"><code>gem 'activerabbit-ai'</code></pre>
      </div>

      <p class="text-gray-600 mb-4">Then run bundle install:</p>

      <!-- Bundle Install Command -->
      <div class="bg-gray-900 rounded-lg p-4 mb-6">
        <div class="flex items-center justify-between mb-2">
          <span class="text-gray-400 text-sm">Terminal</span>
          <button onclick="copyToClipboard('bundle-code')" class="text-gray-400 hover:text-white text-sm">
            📋 Copy
          </button>
        </div>
        <pre id="bundle-code" class="text-green-400 text-sm"><code>bundle install</code></pre>
      </div>

      <!-- Configuration Step -->
      <div class="flex items-center mb-6 pt-6 border-t border-gray-200">
        <span class="inline-flex items-center justify-center h-10 w-10 rounded-full bg-blue-100 text-blue-600 text-lg mr-4">
          ⚙️
        </span>
        <h2 class="text-lg font-medium text-gray-900">Step 2: Configure the Gem</h2>
      </div>

      <p class="text-gray-600 mb-4">Set your ActiveRabbit API key as an environment variable:</p>

      <!-- Environment Variable -->
      <div class="bg-gray-900 rounded-lg p-4 mb-6">
        <div class="flex items-center justify-between mb-2">
          <span class="text-gray-400 text-sm">Environment</span>
          <button onclick="copyToClipboard('env-var-code')" class="text-gray-400 hover:text-white text-sm">
            📋 Copy
          </button>
        </div>
        <pre id="env-var-code" class="text-green-400 text-sm"><code>ACTIVERABBIT_API_KEY=<%= @project.api_token %></code></pre>
      </div>

      <!-- Test Step -->
      <div class="flex items-center mb-6 pt-6 border-t border-gray-200">
        <span class="inline-flex items-center justify-center h-10 w-10 rounded-full bg-green-100 text-green-600 text-lg mr-4">
          🧪
        </span>
        <h2 class="text-lg font-medium text-gray-900">Step 3: Test the Integration</h2>
      </div>

      <p class="text-gray-600 mb-4">Restart your Rails application and trigger an error to test the connection:</p>

      <!-- Test Code -->
      <div class="bg-gray-900 rounded-lg p-4 mb-6">
        <div class="flex items-center justify-between mb-2">
          <span class="text-gray-400 text-sm">Rails Console or Controller</span>
          <button onclick="copyToClipboard('test-code')" class="text-gray-400 hover:text-white text-sm">
            📋 Copy
          </button>
        </div>
        <pre id="test-code" class="text-green-400 text-sm"><code># Test error tracking
ActiveRabbit::Client.track_exception(StandardError.new("Test error from ActiveRabbit!"))

# Test performance tracking
ActiveRabbit::Client.track_performance("test_operation", 100, { custom: "data" })</code></pre>
      </div>

      <!-- Verify Button -->
      <div class="pt-6 border-t border-gray-200">
        <%= form_with url: onboarding_verify_gem_path(@project), method: :post, local: true do |form| %>
          <div class="flex items-center justify-between">
            <% if current_account.projects.count > 1 %>
              <%= link_to dashboard_path,
                  class: "text-sm text-gray-500 hover:text-gray-700" do %>
                ← Back to dashboard
              <% end %>
            <% else %>
              <%= link_to onboarding_new_project_path,
                  class: "text-sm text-gray-500 hover:text-gray-700" do %>
                ← Back to project setup
              <% end %>
            <% end %>

            <%= form.submit "Verify Installation ✓",
                class: "inline-flex items-center px-6 py-3 border border-transparent text-base font-medium rounded-md shadow-sm text-white bg-green-600 hover:bg-green-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500",
                data: { confirm: "Make sure you've installed the gem and restarted your Rails application. Click OK to test the connection." } %>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <!-- Help Sidebar -->
  <div class="lg:col-span-1">
    <!-- Project Info -->
    <div class="bg-white rounded-lg shadow p-6 mb-6">
      <h3 class="text-lg font-medium text-gray-900 mb-4">Project Details</h3>
      <dl class="space-y-3">
        <div>
          <dt class="text-sm font-medium text-gray-500">Project Name</dt>
          <dd class="text-sm text-gray-900"><%= @project.name %></dd>
        </div>
        <div>
          <dt class="text-sm font-medium text-gray-500">Project ID</dt>
          <dd class="text-sm text-gray-900 font-mono"><%= @project.id %></dd>
        </div>
        <div>
          <dt class="text-sm font-medium text-gray-500">API Token</dt>
          <dd class="text-sm text-gray-900 font-mono break-all">
            <span id="api-token" class="blur-sm hover:blur-none transition-all cursor-pointer"
                  title="Click to reveal">
              <%= @project.api_token %>
            </span>
          </dd>
        </div>
      </dl>
    </div>

    <!-- Troubleshooting -->
    <div class="bg-yellow-50 rounded-lg p-6 mb-6">
      <div class="flex">
        <div class="flex-shrink-0">
          <span class="text-yellow-600 text-xl">⚠️</span>
        </div>
        <div class="ml-4">
          <h3 class="text-sm font-medium text-yellow-800 mb-2">Troubleshooting</h3>
          <ul class="text-sm text-yellow-700 space-y-1">
            <li>• Make sure to restart your Rails server after installation</li>
            <li>• Check that your API token is correctly configured</li>
            <li>• Verify your application can reach <%= @project.url.presence || request.base_url %></li>
          </ul>
        </div>
      </div>
    </div>

    <!-- Need Help -->
    <div class="bg-gray-50 rounded-lg p-6">
      <div class="text-center">
        <h3 class="text-sm font-medium text-gray-900 mb-2">Need Help?</h3>
        <p class="text-xs text-gray-600 mb-3">
          Having trouble with the installation?
        </p>
        <a href="#" class="text-sm font-medium text-purple-600 hover:text-purple-700">
          View Documentation →
        </a>
      </div>
    </div>
  </div>
</div>
</div>

<!-- ============================================ -->
<!-- TAB: Log Management                          -->
<!-- ============================================ -->
<div id="panel-logs" class="tab-panel hidden">
<div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
  <div class="lg:col-span-2">
    <div class="bg-white rounded-lg shadow p-6">

      <!-- Step 1: Endpoint -->
      <div class="flex items-center mb-6">
        <span class="inline-flex items-center justify-center h-10 w-10 rounded-full bg-blue-100 text-blue-600 text-lg mr-4">
          1
        </span>
        <h2 class="text-lg font-medium text-gray-900">Send Logs via HTTP API</h2>
      </div>

      <p class="text-gray-600 mb-4">
        Send structured log entries from any language or platform using a simple POST request.
        Logs are ingested asynchronously and appear in your project's log viewer within seconds.
      </p>

      <div class="bg-gray-900 rounded-lg p-4 mb-6">
        <div class="flex items-center justify-between mb-2">
          <span class="text-gray-400 text-sm">Endpoint</span>
        </div>
        <pre class="text-green-400 text-sm"><code>POST <%= request.base_url %>/api/v1/logs</code></pre>
      </div>

      <!-- Step 2: Auth header -->
      <div class="flex items-center mb-6 pt-6 border-t border-gray-200">
        <span class="inline-flex items-center justify-center h-10 w-10 rounded-full bg-blue-100 text-blue-600 text-lg mr-4">
          2
        </span>
        <h2 class="text-lg font-medium text-gray-900">Authenticate with Your Project Token</h2>
      </div>

      <p class="text-gray-600 mb-4">
        Include the <code class="bg-gray-100 px-1.5 py-0.5 rounded text-sm">X-Project-Token</code> header
        in every request. This identifies which project the logs belong to.
      </p>

      <div class="bg-gray-900 rounded-lg p-4 mb-6">
        <div class="flex items-center justify-between mb-2">
          <span class="text-gray-400 text-sm">Header</span>
          <button onclick="copyToClipboard('logs-token-code')" class="text-gray-400 hover:text-white text-sm">
            📋 Copy
          </button>
        </div>
        <pre id="logs-token-code" class="text-green-400 text-sm"><code>X-Project-Token: <%= @project.api_token %></code></pre>
      </div>

      <!-- Step 3: Payload -->
      <div class="flex items-center mb-6 pt-6 border-t border-gray-200">
        <span class="inline-flex items-center justify-center h-10 w-10 rounded-full bg-blue-100 text-blue-600 text-lg mr-4">
          3
        </span>
        <h2 class="text-lg font-medium text-gray-900">Send Log Entries</h2>
      </div>

      <p class="text-gray-600 mb-2">
        Send one or more entries in the <code class="bg-gray-100 px-1.5 py-0.5 rounded text-sm">entries</code>
        array (up to 1,000 per request). Each entry requires a <code class="bg-gray-100 px-1.5 py-0.5 rounded text-sm">message</code> field.
      </p>

      <!-- Field reference -->
      <div class="mb-4 mt-4">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-gray-200">
              <th class="text-left py-2 pr-4 font-medium text-gray-700">Field</th>
              <th class="text-left py-2 pr-4 font-medium text-gray-700">Type</th>
              <th class="text-left py-2 font-medium text-gray-700">Description</th>
            </tr>
          </thead>
          <tbody class="text-gray-600">
            <tr class="border-b border-gray-100">
              <td class="py-1.5 pr-4 font-mono text-xs">message</td>
              <td class="py-1.5 pr-4">string</td>
              <td class="py-1.5"><strong>Required.</strong> The log message.</td>
            </tr>
            <tr class="border-b border-gray-100">
              <td class="py-1.5 pr-4 font-mono text-xs">level</td>
              <td class="py-1.5 pr-4">string/int</td>
              <td class="py-1.5">trace, debug, info (default), warn, error, fatal</td>
            </tr>
            <tr class="border-b border-gray-100">
              <td class="py-1.5 pr-4 font-mono text-xs">source</td>
              <td class="py-1.5 pr-4">string</td>
              <td class="py-1.5">Originating service or component</td>
            </tr>
            <tr class="border-b border-gray-100">
              <td class="py-1.5 pr-4 font-mono text-xs">environment</td>
              <td class="py-1.5 pr-4">string</td>
              <td class="py-1.5">e.g. production, staging, development</td>
            </tr>
            <tr class="border-b border-gray-100">
              <td class="py-1.5 pr-4 font-mono text-xs">params</td>
              <td class="py-1.5 pr-4">object</td>
              <td class="py-1.5">Structured key-value data (searchable)</td>
            </tr>
            <tr class="border-b border-gray-100">
              <td class="py-1.5 pr-4 font-mono text-xs">context</td>
              <td class="py-1.5 pr-4">object</td>
              <td class="py-1.5">Additional metadata</td>
            </tr>
            <tr class="border-b border-gray-100">
              <td class="py-1.5 pr-4 font-mono text-xs">trace_id</td>
              <td class="py-1.5 pr-4">string</td>
              <td class="py-1.5">Distributed trace ID for correlation</td>
            </tr>
            <tr class="border-b border-gray-100">
              <td class="py-1.5 pr-4 font-mono text-xs">span_id</td>
              <td class="py-1.5 pr-4">string</td>
              <td class="py-1.5">Span ID within a trace</td>
            </tr>
            <tr class="border-b border-gray-100">
              <td class="py-1.5 pr-4 font-mono text-xs">request_id</td>
              <td class="py-1.5 pr-4">string</td>
              <td class="py-1.5">HTTP request ID</td>
            </tr>
            <tr>
              <td class="py-1.5 pr-4 font-mono text-xs">occurred_at</td>
              <td class="py-1.5 pr-4">ISO 8601</td>
              <td class="py-1.5">When the log happened (defaults to now)</td>
            </tr>
          </tbody>
        </table>
      </div>

      <!-- Step 4: Examples -->
      <div class="flex items-center mb-6 pt-6 border-t border-gray-200">
        <span class="inline-flex items-center justify-center h-10 w-10 rounded-full bg-green-100 text-green-600 text-lg mr-4">
          4
        </span>
        <h2 class="text-lg font-medium text-gray-900">Examples</h2>
      </div>

      <!-- Language tabs -->
      <div class="mb-4">
        <nav class="flex space-x-2">
          <button onclick="switchLang('curl')" id="lang-curl" class="lang-tab px-3 py-1.5 text-sm font-medium rounded-md bg-gray-900 text-white">cURL</button>
          <button onclick="switchLang('ruby')" id="lang-ruby" class="lang-tab px-3 py-1.5 text-sm font-medium rounded-md bg-gray-100 text-gray-600 hover:bg-gray-200">Ruby</button>
          <button onclick="switchLang('python')" id="lang-python" class="lang-tab px-3 py-1.5 text-sm font-medium rounded-md bg-gray-100 text-gray-600 hover:bg-gray-200">Python</button>
          <button onclick="switchLang('node')" id="lang-node" class="lang-tab px-3 py-1.5 text-sm font-medium rounded-md bg-gray-100 text-gray-600 hover:bg-gray-200">Node.js</button>
        </nav>
      </div>

      <!-- cURL example -->
      <div id="lang-panel-curl" class="lang-panel">
        <div class="bg-gray-900 rounded-lg p-4 mb-6">
          <div class="flex items-center justify-between mb-2">
            <span class="text-gray-400 text-sm">Terminal</span>
            <button onclick="copyToClipboard('curl-example')" class="text-gray-400 hover:text-white text-sm">📋 Copy</button>
          </div>
          <pre id="curl-example" class="text-green-400 text-sm whitespace-pre-wrap"><code>curl -X POST <%= request.base_url %>/api/v1/logs \
  -H "Content-Type: application/json" \
  -H "X-Project-Token: <%= @project.api_token %>" \
  -d '{
    "entries": [
      {
        "level": "info",
        "message": "User signed in",
        "source": "AuthController",
        "environment": "production",
        "params": { "user_id": 42 }
      },
      {
        "level": "error",
        "message": "Payment failed: card_declined",
        "source": "StripeService",
        "environment": "production",
        "trace_id": "tr_abc123",
        "params": { "charge_id": "ch_1234" }
      }
    ]
  }'</code></pre>
        </div>
      </div>

      <!-- Ruby example -->
      <div id="lang-panel-ruby" class="lang-panel hidden">
        <div class="bg-gray-900 rounded-lg p-4 mb-6">
          <div class="flex items-center justify-between mb-2">
            <span class="text-gray-400 text-sm">Ruby</span>
            <button onclick="copyToClipboard('ruby-example')" class="text-gray-400 hover:text-white text-sm">📋 Copy</button>
          </div>
          <pre id="ruby-example" class="text-green-400 text-sm whitespace-pre-wrap"><code>require "net/http"
require "json"

uri = URI("<%= request.base_url %>/api/v1/logs")
http = Net::HTTP.new(uri.host, uri.port)

request = Net::HTTP::Post.new(uri)
request["Content-Type"] = "application/json"
request["X-Project-Token"] = "<%= @project.api_token %>"
request.body = {
  entries: [
    {
      level: "info",
      message: "Order created",
      source: "OrdersController",
      environment: "production",
      params: { order_id: 123, total: "49.99" }
    }
  ]
}.to_json

response = http.request(request)
puts response.body</code></pre>
        </div>
      </div>

      <!-- Python example -->
      <div id="lang-panel-python" class="lang-panel hidden">
        <div class="bg-gray-900 rounded-lg p-4 mb-6">
          <div class="flex items-center justify-between mb-2">
            <span class="text-gray-400 text-sm">Python</span>
            <button onclick="copyToClipboard('python-example')" class="text-gray-400 hover:text-white text-sm">📋 Copy</button>
          </div>
          <pre id="python-example" class="text-green-400 text-sm whitespace-pre-wrap"><code>import requests

response = requests.post(
    "<%= request.base_url %>/api/v1/logs",
    headers={
        "Content-Type": "application/json",
        "X-Project-Token": "<%= @project.api_token %>",
    },
    json={
        "entries": [
            {
                "level": "info",
                "message": "User signed in",
                "source": "auth_service",
                "environment": "production",
                "params": {"user_id": 42},
            }
        ]
    },
)
print(response.json())</code></pre>
        </div>
      </div>

      <!-- Node.js example -->
      <div id="lang-panel-node" class="lang-panel hidden">
        <div class="bg-gray-900 rounded-lg p-4 mb-6">
          <div class="flex items-center justify-between mb-2">
            <span class="text-gray-400 text-sm">Node.js</span>
            <button onclick="copyToClipboard('node-example')" class="text-gray-400 hover:text-white text-sm">📋 Copy</button>
          </div>
          <pre id="node-example" class="text-green-400 text-sm whitespace-pre-wrap"><code>const response = await fetch("<%= request.base_url %>/api/v1/logs", {
  method: "POST",
  headers: {
    "Content-Type": "application/json",
    "X-Project-Token": "<%= @project.api_token %>",
  },
  body: JSON.stringify({
    entries: [
      {
        level: "info",
        message: "User signed in",
        source: "auth-service",
        environment: "production",
        params: { userId: 42 },
      },
    ],
  }),
});
console.log(await response.json());</code></pre>
        </div>
      </div>

      <!-- Response info -->
      <div class="bg-blue-50 border border-blue-200 rounded-lg p-4 mb-6">
        <p class="text-sm text-blue-800">
          <strong>Response:</strong> Returns <code class="bg-blue-100 px-1 py-0.5 rounded text-xs">202 Accepted</code>
          when entries are queued. Logs are processed asynchronously and appear in your
          <%= link_to "log viewer", project_logs_path(@project), class: "underline font-medium" %>
          within seconds.
        </p>
      </div>

      <!-- Back link -->
      <div class="pt-6 border-t border-gray-200">
        <div class="flex items-center justify-between">
          <% if current_account.projects.count > 1 %>
            <%= link_to dashboard_path,
                class: "text-sm text-gray-500 hover:text-gray-700" do %>
              ← Back to dashboard
            <% end %>
          <% else %>
            <%= link_to onboarding_new_project_path,
                class: "text-sm text-gray-500 hover:text-gray-700" do %>
              ← Back to project setup
            <% end %>
          <% end %>

          <%= link_to project_logs_path(@project),
              class: "inline-flex items-center px-6 py-3 border border-transparent text-base font-medium rounded-md shadow-sm text-white bg-purple-600 hover:bg-purple-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-purple-500" do %>
            View Logs →
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <!-- Sidebar -->
  <div class="lg:col-span-1">
    <!-- Project Info -->
    <div class="bg-white rounded-lg shadow p-6 mb-6">
      <h3 class="text-lg font-medium text-gray-900 mb-4">Project Details</h3>
      <dl class="space-y-3">
        <div>
          <dt class="text-sm font-medium text-gray-500">Project Name</dt>
          <dd class="text-sm text-gray-900"><%= @project.name %></dd>
        </div>
        <div>
          <dt class="text-sm font-medium text-gray-500">Project ID</dt>
          <dd class="text-sm text-gray-900 font-mono"><%= @project.id %></dd>
        </div>
        <div>
          <dt class="text-sm font-medium text-gray-500">API Token</dt>
