<% content_for :page_title do %>
  ActiveRabbit Errors
<% end %>

<!-- Errors List / Analytics Toggle -->
<div class="bg-white rounded-xl shadow overflow-hidden border border-gray-200">
    <% if params[:tab] == 'graph' %>
      <div class="border-t border-gray-200 px-6 py-6">
        <!-- Stats + Severity in one line (scroll horizontally on narrow viewports) -->
        <div class="flex flex-nowrap gap-3 overflow-x-auto pb-2 mb-8 min-w-0">
          <%= link_to errors_index_path, class: "flex items-center p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors flex-shrink-0 min-w-[7.5rem]" do %>
            <div class="w-8 h-8 bg-red-100 rounded-full flex items-center justify-center shrink-0">
              <svg class="w-4 h-4 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L3.268 16.5c-.77.833.192 2.5 1.732 2.5z"></path>
              </svg>
            </div>
            <div class="ml-3 min-w-0">
              <p class="text-xs text-gray-500 whitespace-nowrap">Total Errors</p>
              <p class="text-lg font-semibold text-gray-900"><%= number_with_delimiter(@total_errors) %></p>
            </div>
          <% end %>

          <%= link_to errors_index_path(filter: "open"), class: "flex items-center p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors flex-shrink-0 min-w-[7.5rem]" do %>
            <div class="w-8 h-8 bg-yellow-100 rounded-full flex items-center justify-center shrink-0">
              <svg class="w-4 h-4 text-yellow-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
            </div>
            <div class="ml-3 min-w-0">
              <p class="text-xs text-gray-500 whitespace-nowrap">WIP</p>
              <p class="text-lg font-semibold text-gray-900"><%= number_with_delimiter(@open_errors) %></p>
            </div>
          <% end %>

          <%= link_to errors_index_path(filter: "closed"), class: "flex items-center p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors flex-shrink-0 min-w-[7.5rem]" do %>
            <div class="w-8 h-8 bg-purple-100 rounded-full flex items-center justify-center shrink-0">
              <svg class="w-4 h-4 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
            </div>
            <div class="ml-3 min-w-0">
              <p class="text-xs text-gray-500 whitespace-nowrap">Closed</p>
              <p class="text-lg font-semibold text-gray-900"><%= number_with_delimiter(@resolved_errors) %></p>
            </div>
          <% end %>

          <%= link_to errors_index_path(filter: "recent"), class: "flex items-center p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors flex-shrink-0 min-w-[7.5rem]" do %>
            <div class="w-8 h-8 bg-green-100 rounded-full flex items-center justify-center shrink-0">
              <svg class="w-4 h-4 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
            </div>
            <div class="ml-3 min-w-0">
              <p class="text-xs text-gray-500 whitespace-nowrap">Recent (24h)</p>
              <p class="text-lg font-semibold text-gray-900"><%= number_with_delimiter(@recent_errors) %></p>
            </div>
          <% end %>

          <%= link_to errors_index_path(filter: "jobs"), class: "flex items-center p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors flex-shrink-0 min-w-[7.5rem]" do %>
            <div class="w-8 h-8 bg-amber-100 rounded-full flex items-center justify-center shrink-0">
              <svg class="w-4 h-4 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6v6h6v6H4V6zm10 0v6h6v6h-6V6z"></path>
              </svg>
            </div>
            <div class="ml-3 min-w-0">
              <p class="text-xs text-gray-500 whitespace-nowrap">Failed jobs</p>
              <p class="text-lg font-semibold text-gray-900"><%= number_with_delimiter(@failed_jobs_count) %></p>
            </div>
          <% end %>

          <%= link_to errors_index_path(filter: "ai"), class: "flex items-center p-3 rounded-lg transition-colors flex-shrink-0 min-w-[7.5rem] #{params[:filter] == 'ai' ? 'bg-violet-100 ring-2 ring-violet-400' : 'bg-gray-50 hover:bg-violet-50'}" do %>
            <div class="w-8 h-8 bg-gradient-to-br from-violet-100 to-indigo-100 rounded-full flex items-center justify-center shrink-0">
              <svg class="w-4 h-4 text-violet-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"></path>
              </svg>
            </div>
            <div class="ml-3 min-w-0">
              <p class="text-xs text-gray-500 whitespace-nowrap">AI Summaries</p>
              <p class="text-lg font-semibold text-violet-700"><%= number_with_delimiter(@ai_summaries_count) %></p>
            </div>
          <% end %>

          <% [
            { key: "critical", label: "Critical", count: @critical_count, icon_bg: "bg-red-100", dot: "bg-red-500" },
            { key: "high",     label: "High",     count: @high_count,     icon_bg: "bg-orange-100", dot: "bg-orange-500" },
            { key: "medium",   label: "Medium",   count: @medium_count,   icon_bg: "bg-yellow-100", dot: "bg-yellow-400" },
            { key: "low",      label: "Low",      count: @low_count,      icon_bg: "bg-gray-100", dot: "bg-gray-300" }
          ].each do |s| %>
            <%= link_to errors_index_path(filter: s[:key]), class: "flex items-center p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors flex-shrink-0 min-w-[7.5rem]" do %>
              <div class="w-8 h-8 <%= s[:icon_bg] %> rounded-full flex items-center justify-center shrink-0">
                <div class="w-2.5 h-2.5 rounded-full <%= s[:dot] %>"></div>
              </div>
              <div class="ml-3 min-w-0">
                <p class="text-xs text-gray-500 whitespace-nowrap"><%= s[:label] %></p>
                <p class="text-lg font-semibold text-gray-900"><%= number_with_delimiter(s[:count]) %></p>
              </div>
            <% end %>
          <% end %>
        </div>

        <div class="flex items-center justify-between mb-4">
          <h3 class="text-lg font-medium text-gray-900">Analytics</h3>
          <div class="inline-flex bg-gray-100 p-1 rounded-full shadow-inner">
            <% %w[1H 4H 8H 12H 24H 48H 7D 30D].each do |rk| %>
              <% active = (@graph_range_key || '7D') == rk %>
              <%= link_to rk, url_for(params.permit!.to_h.merge(tab: 'graph', range: rk)), class: "ml-1 first:ml-0 px-3 py-1.5 rounded-full text-xs font-medium #{active ? 'bg-white text-indigo-600 shadow ring-1 ring-gray-200' : 'text-gray-600 hover:text-gray-800'}" %>
            <% end %>
          </div>
        </div>

        <% if @graph_counts.present? && @graph_has_data %>
          <% labels = (@graph_labels || []).map { |t| case @graph_range_key; when '1H','4H','8H','12H','24H','48H' then t.strftime('%H:%M'); else t.strftime('%b %d'); end } %>
          <div class="relative" style="height: 300px;">
            <canvas data-controller="graph"
                    data-graph-labels-value='<%= labels.to_json %>'
                    data-graph-counts-value='<%= @graph_counts.to_json %>'
                    data-graph-range-value='<%= @graph_range_key %>'></canvas>
          </div>
        <% else %>
          <div class="text-center text-gray-500 py-8">No data for selected range</div>
        <% end %>
      </div>
    <% elsif @issues.any? || params[:filter].present? %>

    <% if params[:filter] == "ai" %>
      <div class="mx-6 mt-4 mb-2 flex items-center justify-between rounded-lg bg-gradient-to-r from-violet-50 to-indigo-50 border border-violet-200 px-4 py-2.5">
        <div class="flex items-center gap-2 text-sm text-violet-800">
          <svg class="w-4 h-4 text-violet-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"></path>
          </svg>
          <span class="font-medium">Showing only errors with AI summaries</span>
          <span class="text-violet-500">(<%= @ai_summaries_count %> total)</span>
        </div>
        <%= link_to errors_index_path, class: "text-xs text-violet-600 hover:text-violet-800 font-medium underline" do %>
          Clear filter
        <% end %>
      </div>
    <% end %>

    <% if @issues.empty? %>
      <div class="p-12 text-center">
        <% if params[:filter] == "ai" %>
          <div class="w-12 h-12 mx-auto mb-3 rounded-full bg-violet-100 flex items-center justify-center">
            <svg class="w-6 h-6 text-violet-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"></path>
            </svg>
          </div>
          <h3 class="text-lg font-medium text-gray-900 mb-1">No AI summaries yet</h3>
          <p class="text-sm text-gray-500 mb-4">Generate AI analysis on any error to see it here.</p>
        <% elsif params[:filter] == "closed" %>
          <div class="w-12 h-12 mx-auto mb-3 rounded-full bg-green-100 flex items-center justify-center">
            <svg class="w-6 h-6 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
          </div>
          <h3 class="text-lg font-medium text-gray-900 mb-1">No closed errors</h3>
          <p class="text-sm text-gray-500 mb-4">Errors you resolve will appear here.</p>
        <% elsif params[:filter] == "open" %>
          <div class="w-12 h-12 mx-auto mb-3 rounded-full bg-yellow-100 flex items-center justify-center">
            <svg class="w-6 h-6 text-yellow-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
          </div>
          <h3 class="text-lg font-medium text-gray-900 mb-1">No WIP errors</h3>
          <p class="text-sm text-gray-500 mb-4">Errors marked as work-in-progress will appear here.</p>
        <% else %>
          <div class="w-12 h-12 mx-auto mb-3 rounded-full bg-gray-100 flex items-center justify-center">
            <svg class="w-6 h-6 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
          </div>
          <h3 class="text-lg font-medium text-gray-900 mb-1">No errors found</h3>
          <p class="text-sm text-gray-500 mb-4">No errors match the current filter and time period.</p>
        <% end %>
        <%= link_to errors_index_path, class: "text-sm text-indigo-600 hover:text-indigo-800 font-medium" do %>
          &larr; View all errors
        <% end %>
      </div>
    <% else %>
    <!-- Proper HTML Table -->
    <div class="overflow-hidden">
      <table class="w-full divide-y divide-gray-200 table-fixed" style="position: relative;">
        <thead class="bg-white border-b border-gray-200">
          <tr>
            <th class="w-[35%] px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
              <%= sort_link(@q, :exception_class, class: "inline-flex items-center gap-2") do %>
                <span class="inline-flex items-center justify-center w-6 h-6 rounded-md bg-indigo-50 text-sm leading-none">🐰</span>
                <span>Error & Action</span>
              <% end %>
            </th>
            <th class="w-[8%] px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
              <%= sort_link(@q, :severity_order, "Severity", class: "inline-flex items-center") %>
            </th>
            <th class="w-[10%] px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
              <%= sort_link(@q, :last_seen_at, "Last Seen", class: "inline-flex items-center") %>
            </th>
            <th class="w-[7%] px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
              <%= sort_link(@q, :count, "Total", class: "inline-flex items-center") %>
            </th>
            <th class="w-[10%] px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
              <%= sort_link(@q, :events_24h_count, "Impact %", class: "inline-flex items-center") %>
            </th>
            <th class="w-[8%] px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
              <%= sort_link(@q, :has_pr_url, "PR", class: "inline-flex items-center") %>
            </th>
            <th class="w-[10%] px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
              <%= sort_link(@q, :ai_summary, "AI", class: "inline-flex items-center") %>
            </th>
            <th class="w-[12%] px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
              <%= sort_link(@q, :status, "Status", class: "inline-flex items-center") %>
            </th>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-gray-200">
          <% @issues.each do |issue| %>
            <tr class="hover:bg-gray-50 hover:cursor-pointer transition-colors" onclick="window.location.href='<%=
              if @current_project
                "/#{@current_project.slug}/errors/#{issue.id}"
              elsif @project
                project_error_path(@project, issue)
              else
                error_path(issue)
              end %>'">
              <!-- Error & Action -->
              <td class="px-4 py-4 overflow-hidden">
                <div class="flex items-start">
                  <div class="flex-shrink-0 mt-1 w-2.5 h-2.5 flex items-center justify-center" aria-hidden="true">
                    <% dot_sev = (issue.severity || 'low').to_s.downcase %>
                    <% dot_classes = { 'critical' => 'bg-red-500', 'high' => 'bg-orange-500', 'medium' => 'bg-yellow-400', 'low' => 'bg-gray-300' } %>
                    <span class="block w-2.5 h-2.5 rounded-full <%= dot_classes.fetch(dot_sev, 'bg-gray-300') %>" title="<%= dot_sev.capitalize %> severity"></span>
                  </div>
                  <div class="ml-3 min-w-0">
                  <div class="flex items-center space-x-2 mb-0.5 flex-wrap gap-1">
                    <span class="text-sm font-medium text-indigo-600">
                      <%= issue.exception_class %>
                    </span>
                    <span class="inline-flex items-center px-1.5 py-0.5 rounded text-xs font-medium bg-gray-100 text-gray-800">
                      <%= truncate(issue.project&.name || 'Unknown', length: 15) %>
                    </span>
                    <% if (@issue_ids_with_job_failures || Set.new).include?(issue.id) %>
                      <span class="inline-flex items-center px-1.5 py-0.5 rounded text-xs font-medium bg-amber-100 text-amber-800" title="From Sidekiq/Solid Queue job">Job</span>
                    <% end %>
                  </div>
                  <% desc = error_explanation(issue.exception_class) %>
                  <% short_text = desc.presence || issue.sample_message.presence || issue.controller_action %>
                  <div class="text-xs text-gray-500 min-w-0 truncate" title="<%= short_text %>">
                    <%= truncate(short_text.to_s, length: 120) %>
                  </div>
                  </div>
                </div>
              </td>

              <!-- Severity -->
              <td class="px-4 py-4">
                <% sev = (issue.severity || 'low').to_s.downcase %>
                <% sev_badge = {
                  'critical' => 'bg-red-100 text-red-700 border-red-200',
                  'high'     => 'bg-orange-100 text-orange-700 border-orange-200',
                  'medium'   => 'bg-yellow-50 text-yellow-700 border-yellow-200',
                  'low'      => 'bg-gray-50 text-gray-500 border-gray-200'
                } %>
                <% sev_dot = { 'critical' => 'bg-red-500', 'high' => 'bg-orange-500', 'medium' => 'bg-yellow-400', 'low' => 'bg-gray-300' }.fetch(sev, 'bg-gray-300') %>
                <span class="inline-flex items-center gap-1.5 px-2 py-0.5 rounded-md text-xs font-semibold border <%= sev_badge.fetch(sev, sev_badge['low']) %>">
                  <span class="w-2 h-2 rounded-full flex-shrink-0 <%= sev_dot %>" title="<%= sev.capitalize %>"></span>
                  <%= sev.capitalize %>
                </span>
              </td>

              <!-- Last Seen -->
              <td class="px-4 py-4">
                <div class="relative group">
                  <div class="text-sm text-gray-900 cursor-default" title="<%= time_ago_in_words(issue.last_seen_at).gsub('about ', '') %> ago"><%= last_seen_short(issue.last_seen_at) %></div>
                  <div class="absolute bottom-full left-0 mb-2 px-3 py-1.5 rounded-lg bg-gray-900 text-white text-xs font-medium whitespace-nowrap opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-150 shadow-lg z-50 pointer-events-none">
                    <%= time_ago_in_words(issue.last_seen_at).gsub('about ', '') %> ago
                    <span class="block mt-0.5 text-gray-300"><%= issue.last_seen_at.strftime("%b %d, %Y at %H:%M") %></span>
                    <div class="absolute top-full left-4 -mt-px border-4 border-transparent border-t-gray-900"></div>
                  </div>
                </div>
              </td>

              <!-- Total Count -->
              <td class="px-4 py-4">
                <div class="text-sm font-semibold text-gray-900"><%= number_with_delimiter(issue.count || 0) %></div>
              </td>

              <!-- Impact % (24h) -->
              <td class="px-4 py-4">
                <% issue_24h = (@events_24h_by_issue_id || {})[issue.id].to_i %>
                <% impact = (@total_events_24h.to_i > 0 && issue_24h > 0) ? ((issue_24h.to_f / @total_events_24h.to_f) * 100).round(2) : 0.0 %>
                <% if issue_24h > 0 %>
                  <div class="text-sm font-semibold <%= impact > 50 ? 'text-red-600' : 'text-gray-900' %>"><%= impact > 0 ? "~#{impact}%" : "<1%" %></div>
                  <div class="text-xs text-gray-500"><%= number_with_delimiter(issue_24h) %> in 24h</div>
                <% else %>
                  <div class="text-xs text-gray-400">0%</div>
                  <div class="text-xs text-gray-400">0 in 24h</div>
                <% end %>
              </td>

              <!-- PR -->
              <td class="px-4 py-4" onclick="event.stopPropagation();">
                <% if (pr_url = issue.github_pr_url).present? %>
                  <%= link_to pr_url, target: "_blank", rel: "noopener", class: "inline-flex items-center px-2 py-1 text-xs font-medium text-gray-600 hover:text-gray-900 focus:outline-none" do %>
                    <svg class="w-4 h-4" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
                      <path fill-rule="evenodd" d="M8 0C3.58 0 0 3.58 0 8a8 8 0 005.47 7.59c.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82a7.57 7.57 0 012-.27c.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.19 0 .21.15.46.55.38A8.01 8.01 0 0016 8c0-4.42-3.58-8-8-8z" clip-rule="evenodd" />
                    </svg>
                    <span class="ml-1">GitHub</span>
                  <% end %>
                <% else %>
                  <span class="text-xs text-gray-400">—</span>
                <% end %>
              </td>

              <!-- AI -->
              <td class="px-4 py-4" onclick="event.stopPropagation();">
                <% _ai_link = if @current_project
                                "/#{@current_project.slug}/errors/#{issue.id}#ai-analysis"
                              elsif @project
                                project_error_path(@project, issue, anchor: 'ai-analysis')
                              else
                                error_path(issue, anchor: 'ai-analysis')
                              end %>
                <% _ai_quota_ok = !current_user&.account || current_user.account.within_quota?(:ai_summaries) %>
                <% if issue.ai_summary.present? %>
                  <%# Has AI summary — purple active badge %>
                  <%= link_to _ai_link, class: "inline-flex items-center px-3 py-1.5 text-xs font-semibold rounded-full shadow-sm focus:outline-none text-white bg-gradient-to-r from-indigo-500 to-violet-500 hover:from-indigo-600 hover:to-violet-600" do %>
                    <svg class="w-3 h-3 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
                    </svg>
                    AI
                  <% end %>
                <% elsif !_ai_quota_ok %>
                  <% _idx_plan_key = current_user.account.send(:effective_plan_key) rescue :free %>
                  <% _idx_is_paid = %i[team business].include?(_idx_plan_key) %>
                  <% if _idx_is_paid %>
                    <%# No summary + quota exceeded on paid plan — "Buy more" badge %>
                    <%= link_to _ai_link, class: "group inline-flex items-center px-3 py-1.5 text-xs font-semibold rounded-full shadow-sm focus:outline-none border border-emerald-200 bg-emerald-50 text-emerald-700 hover:bg-emerald-600 hover:text-white hover:border-emerald-600 transition-colors", title: "AI quota reached — buy more analyses" do %>
                      <svg class="w-3 h-3 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
                      </svg>
                      <span class="group-hover:hidden">AI</span>
                      <span class="hidden group-hover:inline">Buy More</span>
                    <% end %>
                  <% else %>
                    <%# No summary + quota exceeded on free/trial — upgrade badge with tooltip %>
                    <div class="relative group">
                      <%= link_to (plan_path rescue "/plan"), class: "inline-flex items-center px-3 py-1.5 text-xs font-semibold rounded-full shadow-sm focus:outline-none border border-indigo-200 bg-indigo-50 text-indigo-600 hover:bg-indigo-600 hover:text-white hover:border-indigo-600 transition-colors" do %>
                        <svg class="w-3 h-3 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
                        </svg>
                        AI
                      <% end %>
                      <div class="absolute bottom-full left-1/2 -translate-x-1/2 mb-2 px-2.5 py-1 rounded-md bg-gray-900 text-white text-xs font-medium whitespace-nowrap opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-150 shadow-lg z-50 pointer-events-none">
                        Upgrade
                        <div class="absolute top-full left-1/2 -translate-x-1/2 -mt-px border-4 border-transparent border-t-gray-900"></div>
                      </div>
                    </div>
                  <% end %>
                <% else %>
                  <%# No summary, quota OK — gray generate badge %>
                  <%= link_to _ai_link, class: "inline-flex items-center px-3 py-1.5 text-xs font-semibold rounded-full shadow-sm focus:outline-none text-gray-600 bg-gray-100 hover:bg-gray-200" do %>
                    <svg class="w-3 h-3 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
                    </svg>
                    AI
                  <% end %>
                <% end %>
              </td>

              <!-- Status -->
              <td class="px-4 py-4" onclick="event.stopPropagation();">
                <%= render "errors/status_dropdown_list", issue: issue, project: @project %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <!-- Pagination (countless — no total count to avoid expensive COUNT query) -->
    <% if @pagy && (@pagy.prev || @pagy.next) %>
      <div class="px-6 py-4 border-t border-gray-200">
        <div class="flex items-center justify-between">
          <div class="hidden sm:block">
            <p class="text-sm text-gray-700">
              Page <span class="font-medium"><%= @pagy.page %></span>
              <% if @issues.size == 25 %> · showing 25 errors<% end %>
            </p>
          </div>
          <div class="flex-1 flex justify-end">
            <div class="inline-flex rounded-md shadow-sm" role="group" aria-label="Pagination">
              <% if @pagy.prev %>
                <%= link_to pagy_url_for(@pagy, @pagy.prev), rel: "prev",
                    class: "inline-flex items-center gap-2 px-3 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-l-md hover:bg-gray-50" do %>
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" /></svg>
                  Prev
                <% end %>
              <% else %>
                <span class="inline-flex items-center gap-2 px-3 py-2 text-sm font-medium text-gray-400 bg-gray-50 border border-gray-200 rounded-l-md cursor-not-allowed">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" /></svg>
                  Prev
                </span>
              <% end %>
              <% if @pagy.next %>
                <%= link_to pagy_url_for(@pagy, @pagy.next), rel: "next",
                    class: "inline-flex items-center gap-2 px-3 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 border-l-0 rounded-r-md hover:bg-gray-50" do %>
                  Next
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
                <% end %>
              <% else %>
                <span class="inline-flex items-center gap-2 px-3 py-2 text-sm font-medium text-gray-400 bg-gray-50 border border-gray-200 border-l-0 rounded-r-md cursor-not-allowed">
                  Next
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
                </span>
              <% end %>
            </div>
          </div>
        </div>
      </div>
    <% end %>
    <% end %> <%# close if @issues.empty? && params[:filter]=="ai" / else %>
  <% else %>
    <div class="p-12 text-center">
      <div class="w-12 h-12 mx-auto mb-4 text-gray-400">
        🐰
      </div>
      <h3 class="text-lg font-medium text-gray-900 mb-2">No errors captured yet</h3>
      <p class="text-gray-500 mb-4">ActiveRabbit is monitoring your applications. Errors will appear here when they occur.</p>
      <% if Rails.env.development? %>
        <p class="text-xs text-gray-400 mt-4 font-mono">
          Debug: Issues: <%= @issues.size %>, Total: <%= @total_errors %>, Project: <%= @current_project&.name %>
        </p>
      <% end %>
    </div>
  <% end %>
</div>
