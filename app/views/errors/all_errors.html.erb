<% content_for :page_title do %>
  All Errors - Bento Box View
<% end %>

<div class="space-y-8">
  <!-- Title -->
  <div>
    <h1 class="text-2xl font-bold text-gray-900">All Errors</h1>
    <p class="text-sm text-gray-500 mt-1">Square tiles on a 12-column grid — box size follows frequency; similar occurrence counts share the same size.</p>
  </div>

  <!-- Header with time period filter -->
  <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
    <!-- Time period filter -->
    <div class="flex items-center gap-2">
      <span class="text-sm text-gray-500">Period:</span>
      <div class="inline-flex bg-gray-100 p-1 rounded-lg">
        <% %w[all 1h 1d 7d 30d].each do |period| %>
          <% period_labels = { "all" => "All time", "1h" => "1 hour", "1d" => "24 hours", "7d" => "7 days", "30d" => "30 days" } %>
          <% active = @current_period == period %>
          <%= link_to all_errors_path(period: (period == "all" ? nil : period)), 
              class: "px-3 py-1.5 rounded-md text-xs font-medium transition-colors #{active ? 'bg-white text-indigo-600 shadow-sm' : 'text-gray-600 hover:text-gray-800'}" do %>
            <%= period_labels[period] %>
          <% end %>
        <% end %>
      </div>
    </div>
  </div>

  <!-- Bento Box Grid -->
  <% if @issues_with_sizes.any? %>
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-8">
      <%# 12 columns everywhere so small spans (2–3) show many tiles per row, not a 2-column look %>
      <div class="grid grid-cols-12 gap-2 sm:gap-3 md:gap-4" style="grid-auto-flow: dense;">
        <% @issues_with_sizes.each do |item| %>
          <% issue = item[:issue] %>
          <% cols = item[:cols].to_i.clamp(1, 12) %>
          <% size_class = item[:size_class] %>
          
          <% error_url = if @current_project
                          "/#{@current_project.slug}/errors/#{issue.id}"
                        elsif @project
                          project_error_path(@project, issue)
                        else
                          error_path(issue)
                        end %>
          
          <% sev = (issue.severity || 'low').to_s.downcase %>
          <% sev_colors = {
            'critical' => { bg: 'bg-red-50', border: 'border-red-200', text: 'text-red-700', dot: 'bg-red-500', hover: 'hover:bg-red-100' },
            'high'     => { bg: 'bg-orange-50', border: 'border-orange-200', text: 'text-orange-700', dot: 'bg-orange-500', hover: 'hover:bg-orange-100' },
            'medium'   => { bg: 'bg-yellow-50', border: 'border-yellow-200', text: 'text-yellow-700', dot: 'bg-yellow-400', hover: 'hover:bg-yellow-100' },
            'low'      => { bg: 'bg-gray-50', border: 'border-gray-200', text: 'text-gray-600', dot: 'bg-gray-300', hover: 'hover:bg-gray-100' }
          } %>
          <% colors = sev_colors.fetch(sev, sev_colors['low']) %>
          
          <% 
            padding = case size_class
            when 'huge' then 'p-8'
            when 'xlarge' then 'p-7'
            when 'large' then 'p-6'
            when 'medium-large' then 'p-5'
            when 'medium', 'medium-small' then 'p-4'
            when 'small' then 'p-3'
            else 'p-2.5'
            end
          %>
          <% grid_span_style = "grid-column: span #{cols};" %>
          <%= link_to error_url, 
              class: "group relative min-w-0 aspect-square rounded-xl border-2 #{colors[:border]} #{colors[:bg]} #{colors[:hover]} transition-all duration-200 hover:shadow-lg hover:scale-[1.02] #{padding} flex flex-col justify-between overflow-hidden",
              style: grid_span_style do %>
            
            <!-- Decorative gradient overlay -->
            <div class="absolute inset-0 opacity-5 bg-gradient-to-br from-indigo-400 via-purple-400 to-pink-400 pointer-events-none"></div>
            
            <!-- Content -->
            <div class="relative z-10 flex flex-col h-full">
              <!-- Header with severity and count -->
              <div class="flex items-start justify-between mb-2">
                <div class="flex items-center gap-2">
                  <span class="w-2.5 h-2.5 rounded-full <%= colors[:dot] %> flex-shrink-0"></span>
                  <% if size_class != 'tiny' && size_class != 'small' %>
                    <span class="text-xs font-semibold <%= colors[:text] %> uppercase tracking-wide">
                      <%= sev %>
                    </span>
                  <% end %>
                </div>
                <div class="text-right">
                  <% 
                    count_size = case size_class
                    when 'huge' then 'text-4xl'
                    when 'xlarge' then 'text-3xl'
                    when 'large' then 'text-2xl'
                    when 'medium-large' then 'text-xl'
                    when 'medium', 'medium-small' then 'text-lg'
                    when 'small' then 'text-base'
                    else 'text-sm'
                    end
                  %>
                  <div class="<%= count_size %> font-bold text-gray-900"><%= number_with_delimiter(issue.count) %></div>
                  <% if size_class != 'tiny' && size_class != 'small' %>
                    <div class="text-xs text-gray-500">occurrences</div>
                  <% end %>
                </div>
              </div>

              <!-- Exception class -->
              <div class="mb-2">
                <% 
                  title_size = case size_class
                  when 'huge' then 'text-xl'
                  when 'xlarge' then 'text-lg'
                  when 'large' then 'text-base'
                  when 'medium-large' then 'text-sm'
                  when 'medium', 'medium-small' then 'text-xs'
                  else 'text-xs'
                  end
                  title_clamp = case size_class
                  when 'huge' then 'line-clamp-4'
                  when 'xlarge' then 'line-clamp-4'
                  when 'large' then 'line-clamp-3'
                  when 'medium-large' then 'line-clamp-2'
                  else 'line-clamp-1'
                  end
                %>
                <h3 class="<%= title_size %> font-bold text-gray-900 <%= title_clamp %> group-hover:text-indigo-600 transition-colors">
                  <%= issue.exception_class %>
                </h3>
              </div>

              <!-- Message/description -->
              <div class="flex-1 mb-3">
                <% desc = error_explanation(issue.exception_class) %>
                <% short_text = desc.presence || issue.sample_message.presence || issue.controller_action %>
                <% 
                  line_clamp = case size_class
                  when 'huge' then 'line-clamp-8'
                  when 'xlarge' then 'line-clamp-7'
                  when 'large' then 'line-clamp-6'
                  when 'medium-large' then 'line-clamp-4'
                  when 'medium' then 'line-clamp-3'
                  when 'medium-small' then 'line-clamp-2'
                  else 'line-clamp-1'
                  end
                  truncate_length = case size_class
                  when 'huge' then 400
                  when 'xlarge' then 350
                  when 'large' then 300
                  when 'medium-large' then 200
                  when 'medium' then 150
                  when 'medium-small' then 100
                  when 'small' then 60
                  else 40
                  end
                %>
                <p class="text-xs text-gray-600 <%= line_clamp %>">
                  <%= truncate(short_text.to_s, length: truncate_length) %>
                </p>
              </div>

              <!-- Footer with controller action and last seen -->
              <% if size_class != 'tiny' %>
                <div class="flex items-center justify-between text-xs text-gray-500 border-t border-gray-200 pt-2 mt-auto">
                  <div class="flex items-center gap-1.5 min-w-0">
                    <% if size_class != 'small' %>
                      <svg class="w-3.5 h-3.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
                      </svg>
                    <% end %>
                    <span class="truncate"><%= truncate(issue.controller_action, length: size_class == 'small' ? 15 : 25) %></span>
                  </div>
                  <div class="flex items-center gap-1.5 flex-shrink-0">
                    <% if size_class != 'small' %>
                      <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                      </svg>
                    <% end %>
                    <span><%= last_seen_short(issue.last_seen_at) %></span>
                  </div>
                </div>
              <% end %>

              <!-- Project badge (if applicable) -->
              <% if issue.project && size_class != 'tiny' && size_class != 'small' %>
                <div class="mt-2">
                  <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-white/60 text-gray-700 border border-gray-200">
                    <%= truncate(issue.project.name, length: 20) %>
                  </span>
                </div>
              <% end %>
            </div>

            <!-- Hover arrow indicator -->
            <div class="absolute top-4 right-4 opacity-0 group-hover:opacity-100 transition-opacity">
              <svg class="w-5 h-5 text-indigo-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
              </svg>
            </div>
          <% end %>
        <% end %>
      </div>
    </div>
  <% else %>
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-12 text-center">
      <div class="w-16 h-16 mx-auto mb-4 rounded-full bg-gray-100 flex items-center justify-center">
        <svg class="w-8 h-8 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
        </svg>
      </div>
      <h3 class="text-lg font-medium text-gray-900 mb-2">No errors found</h3>
      <p class="text-sm text-gray-500 mb-4">No errors match the current filter and time period.</p>
      <%= link_to errors_index_path, class: "text-sm text-indigo-600 hover:text-indigo-800 font-medium" do %>
        &larr; View all errors
      <% end %>
    </div>
  <% end %>
</div>

<style>
  /* Custom line-clamp utilities for different sizes */
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .line-clamp-3 {
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .line-clamp-4 {
    display: -webkit-box;
    -webkit-line-clamp: 4;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .line-clamp-5 {
    display: -webkit-box;
    -webkit-line-clamp: 5;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .line-clamp-6 {
    display: -webkit-box;
    -webkit-line-clamp: 6;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .line-clamp-7 {
    display: -webkit-box;
    -webkit-line-clamp: 7;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .line-clamp-8 {
    display: -webkit-box;
    -webkit-line-clamp: 8;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
