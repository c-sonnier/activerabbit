         data-controller="auto-ai-summary">
      <div class="px-6 py-5 bg-gradient-to-r from-violet-50 to-white border-b border-gray-100">
        <div class="flex items-center">
          <div class="flex-shrink-0 w-10 h-10 bg-violet-100 rounded-lg flex items-center justify-center">
            <svg class="w-5 h-5 text-violet-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
