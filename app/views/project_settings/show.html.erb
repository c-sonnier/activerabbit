<% content_for :page_title do %>
  <%= @project.name %> - Settings
<% end %>

<div class="max-w-4xl mx-auto">
  <!-- Header -->
  <div class="mb-8">
    <nav class="flex items-center space-x-2 text-sm text-gray-500 mb-4">
      <%= link_to "Dashboard", dashboard_path, class: "hover:text-gray-700" %>
      <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
        <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"></path>
      </svg>
      <%= link_to @project.name, project_slug_errors_path(@project.slug), class: "hover:text-gray-700" %>
      <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
        <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"></path>
      </svg>
      <span class="text-gray-900">Settings</span>
    </nav>

    <h1 class="text-2xl font-bold text-gray-900">Project Settings</h1>
    <p class="text-gray-600 mt-1">Configure notifications and integrations for <%= @project.name %></p>
  </div>

  <!-- Project Details Card -->
  <%= form_with model: @project, url: project_settings_path(@project), method: :patch, local: true do |f| %>
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 mb-10 overflow-hidden mb-4">
      <!-- Header with gradient accent -->
      <div class="px-6 py-5 bg-gradient-to-r from-indigo-50 to-white border-b border-gray-100">
        <div class="flex items-center">
          <div class="flex-shrink-0 w-10 h-10 bg-indigo-100 rounded-lg flex items-center justify-center">
            <svg class="w-5 h-5 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path>
            </svg>
          </div>
          <div class="ml-4">
            <h3 class="text-lg font-semibold text-gray-900">Project Details</h3>
            <p class="text-sm text-gray-500">General information about your project</p>
          </div>
        </div>
      </div>

      <div class="p-8">
        <!-- Basic Info Section -->
        <div class="mb-10">
          <h4 class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-5">Basic Information</h4>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-x-8 gap-y-6">
            <!-- Project Name -->
            <div class="space-y-1.5">
              <label for="project_name" class="flex items-center text-sm font-medium text-gray-700">
                <svg class="w-4 h-4 mr-2 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"></path>
                </svg>
                Project Name
              </label>
              <%= f.text_field :name,
                  class: "block w-full px-4 py-2.5 bg-gray-50 border border-gray-200 rounded-lg text-gray-900 text-sm transition-all duration-200 focus:bg-white focus:outline-none focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500",
                  placeholder: "My Awesome Project" %>
            </div>

            <!-- Environment -->
            <div class="space-y-1.5">
              <label for="project_environment" class="flex items-center text-sm font-medium text-gray-700">
                <svg class="w-4 h-4 mr-2 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2m-2-4h.01M17 16h.01"></path>
                </svg>
                Environment
              </label>
              <%= f.select :environment,
                  options_for_select([
                    ['Production', 'production'],
                    ['Staging', 'staging'],
                    ['Development', 'development']
                  ], @project.environment),
                  { include_blank: 'Select environment...' },
                  class: "block w-full px-4 py-2.5 bg-gray-50 border border-gray-200 rounded-lg text-gray-900 text-sm transition-all duration-200 focus:bg-white focus:outline-none focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 appearance-none cursor-pointer" %>
            </div>
          </div>
        </div>

        <!-- Technical Info Section -->
        <div class="mb-10">
          <h4 class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-5">Technical Details</h4>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-x-8 gap-y-6">
            <!-- Slug -->
            <div class="space-y-1.5">
              <label for="project_slug" class="flex items-center text-sm font-medium text-gray-700">
                <svg class="w-4 h-4 mr-2 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"></path>
                </svg>
                Slug
              </label>
              <div class="relative">
                <%= f.text_field :slug,
                    class: "block w-full pl-4 pr-10 py-2.5 bg-gray-50 border border-gray-200 rounded-lg text-gray-900 text-sm font-mono transition-all duration-200 focus:bg-white focus:outline-none focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500",
                    placeholder: "my-project" %>
                <div class="absolute inset-y-0 right-0 flex items-center pr-3 pointer-events-none">
                  <span class="text-xs text-gray-400 bg-gray-100 px-1.5 py-0.5 rounded">URL</span>
                </div>
              </div>
              <p class="text-xs text-gray-500 flex items-center mt-1">
                <svg class="w-3 h-3 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
                Used in URLs and API calls
              </p>
            </div>

            <!-- URL -->
            <div class="space-y-1.5">
              <label for="project_url" class="flex items-center text-sm font-medium text-gray-700">
                <svg class="w-4 h-4 mr-2 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"></path>
                </svg>
                Project URL
              </label>
              <%= f.url_field :url,
                  class: "block w-full px-4 py-2.5 bg-gray-50 border border-gray-200 rounded-lg text-gray-900 text-sm transition-all duration-200 focus:bg-white focus:outline-none focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500",
                  placeholder: "https://myapp.com" %>
            </div>

            <!-- Tech Stack -->
            <div class="space-y-1.5 md:col-span-2">
              <label for="project_tech_stack" class="flex items-center text-sm font-medium text-gray-700">
                <svg class="w-4 h-4 mr-2 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"></path>
                </svg>
                Tech Stack
              </label>
              <%= f.text_field :tech_stack,
                  class: "block w-full px-4 py-2.5 bg-gray-50 border border-gray-200 rounded-lg text-gray-900 text-sm transition-all duration-200 focus:bg-white focus:outline-none focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500",
                  placeholder: "Rails 7, PostgreSQL, Redis, Sidekiq" %>
            </div>
          </div>
        </div>

        <!-- Description Section -->
        <div class="mb-8">
          <h4 class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-5">Description</h4>
          <div class="space-y-1.5">
            <label for="project_description" class="flex items-center text-sm font-medium text-gray-700">
              <svg class="w-4 h-4 mr-2 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h7"></path>
              </svg>
              Project Description
            </label>
            <%= f.text_area :description,
                rows: 4,
                class: "block w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-lg text-gray-900 text-sm transition-all duration-200 focus:bg-white focus:outline-none focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 resize-none",
                placeholder: "Describe your project, its purpose, and any important notes for error tracking..." %>
          </div>
        </div>

        <!-- Action Bar -->
        <div class="flex items-center justify-between pt-6 border-t border-gray-100">
          <p class="text-xs text-gray-400">
            <svg class="w-4 h-4 inline mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
            Last updated: <%= @project.updated_at.strftime("%b %d, %Y at %I:%M %p") %>
          </p>
          <%= f.submit "Save Changes",
              class: "inline-flex items-center px-5 py-2.5 rounded-lg bg-indigo-600 text-white text-sm font-medium shadow-sm hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 transition-all duration-200" %>
        </div>
      </div>
    </div>
  <% end %>

  <!-- API Token Card -->
  <div class="bg-white rounded-xl shadow-sm border border-gray-200 mb-10 overflow-hidden mb-4">
    <div class="px-6 py-5 bg-gradient-to-r from-blue-50 to-white border-b border-gray-100">
      <div class="flex items-center">
        <div class="flex-shrink-0 w-10 h-10 bg-blue-100 rounded-lg flex items-center justify-center">
          <svg class="w-5 h-5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 7a2 2 0 012 2m0 0a2 2 0 012 2m-2-2h-6m6 0v6a2 2 0 01-2 2H9a2 2 0 01-2-2V9a2 2 0 012-2h6m-6 0a2 2 0 012-2m0 0h6a2 2 0 012 2M9 7h6"></path>
          </svg>
        </div>
        <div class="ml-4">
          <h3 class="text-lg font-semibold text-gray-900">API Token</h3>
          <p class="text-sm text-gray-500">Use this token to authenticate your application with ActiveRabbit</p>
        </div>
      </div>
    </div>
    <div class="p-6">
      <% if @api_tokens.any? %>
        <% token = @api_tokens.first %>
        <div class="p-4 bg-gray-50 rounded-lg">
          <div class="flex items-center justify-between mb-3">
            <p class="text-sm font-medium text-gray-900"><%= token.name %></p>
            <span class="px-2 py-1 text-xs font-medium rounded-full bg-green-100 text-green-800">
              Active
            </span>
          </div>
          <div class="bg-white p-3 rounded border flex items-center justify-between">
            <p class="text-sm text-gray-700 font-mono break-all select-all flex-1 mr-3"><%= token.token %></p>
            <button onclick="copyToClipboard('<%= token.token %>')" class="flex-shrink-0 p-2 text-gray-400 hover:text-gray-600 hover:bg-gray-100 rounded transition-colors" title="Copy to clipboard">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"></path>
              </svg>
            </button>
          </div>
        </div>
        <div class="mt-4">
          <div class="flex items-center justify-between">
            <p class="text-sm text-gray-500">
              Use this token in your application's ActiveRabbit configuration
            </p>
            <div class="flex items-center space-x-3">
              <button type="button"
                      onclick="toggleFullConfig()"
                      class="inline-flex items-center px-3 py-2 border border-gray-300 text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500">
                <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 4h13M8 9h13M3 14h18M3 19h18"></path>
                </svg>
                Full config
              </button>
              <%= button_to "Regenerate Token",
                  regenerate_token_project_path(@project),
                  method: :post,
                  data: { confirm: "Are you sure you want to regenerate the API token?\n\nThis will:\n• Invalidate the current token immediately\n• Require updating all applications using this token\n• Cannot be undone\n\nContinue?" },
                  class: "inline-flex items-center px-3 py-2 border border-red-300 text-sm font-medium rounded-md text-red-700 bg-white hover:bg-red-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500" %>
            </div>
          </div>

          <!-- Inline full config panel -->
          <div id="full-config-panel" class="mt-4 hidden">
            <div class="bg-gray-900 rounded-lg p-4">
              <div class="flex items-center justify-between mb-2">
                <span class="text-gray-400 text-xs sm:text-sm">config/initializers/activerabbit.rb</span>
                <button id="copy-full-config-btn"
                        type="button"
                        onclick="copyInitializerConfig()"
                        class="text-gray-400 hover:text-white text-xs sm:text-sm">
                  📋 Copy
                </button>
              </div>
              <pre id="full-config-code" class="text-green-400 text-xs sm:text-sm overflow-x-auto select-text whitespace-pre"><code><%= render "shared/full_client_config_code", project: @project %></code></pre>
            </div>
          </div>
        </div>
      <% else %>
        <div class="text-center py-8 text-gray-500">
          <svg class="w-12 h-12 mx-auto text-gray-400 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 7a2 2 0 012 2m0 0a2 2 0 012 2m-2-2h-6m6 0v6a2 2 0 01-2 2H9a2 2 0 01-2-2V9a2 2 0 012-2h6m-6 0a2 2 0 012-2m0 0h6a2 2 0 012 2M9 7h6"></path>
          </svg>
          <p>No active API token found.</p>
          <p class="text-sm mt-1">Click "Generate Token" to create one.</p>
                    <%= button_to "Generate Token",
                regenerate_token_project_path(@project),
                method: :post,
                data: { confirm: "Are you sure you want to generate a new API token?\n\nThis will create a new token for your project.\n\nContinue?" },
                class: "mt-4 inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500" %>
        </div>
      <% end %>
    </div>
  </div>

  <!-- GitHub Integration Card -->
  <div class="bg-white rounded-xl shadow-sm border border-gray-200 mb-10 overflow-hidden mb-4">
    <div class="px-6 py-5 bg-gradient-to-r from-gray-50 to-white border-b border-gray-100">
      <div class="flex items-center justify-between">
        <div class="flex items-center">
          <div class="flex-shrink-0 w-10 h-10 bg-gray-100 rounded-lg flex items-center justify-center">
            <svg viewBox="0 0 16 16" width="20" height="20" class="text-gray-800" aria-hidden="true"><path fill="currentColor" d="M8 0C3.58 0 0 3.58 0 8a8 8 0 005.47 7.59c.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82a7.5 7.5 0 012 0c1.53-1.03 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0016 8c0-4.42-3.58-8-8-8z"></path></svg>
          </div>
          <div class="ml-4">
            <h3 class="text-lg font-semibold text-gray-900">GitHub Settings</h3>
            <p class="text-sm text-gray-500">Connect your repository for automatic PR creation</p>
          </div>
        </div>
        <% if @project.settings['github_installation_id'].present? %>
          <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
            <svg class="w-3 h-3 mr-1" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
            </svg>
            Connected
          </span>
        <% end %>
      </div>
    </div>
    <div class="p-6">
      <% if @project.settings['github_installation_id'].present? %>
        <!-- Connected State: Show repo info and branch settings -->
        <div class="space-y-4">
          <div class="bg-gray-50 rounded-lg p-4 border border-gray-200">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              <div>
                <label class="block text-xs font-medium text-gray-500 uppercase tracking-wide mb-1">Repository</label>
                <div class="flex items-center">
                  <svg viewBox="0 0 16 16" width="16" height="16" class="mr-2 text-gray-600" aria-hidden="true"><path fill="currentColor" d="M2 2.5A2.5 2.5 0 014.5 0h8.75a.75.75 0 01.75.75v12.5a.75.75 0 01-.75.75h-2.5a.75.75 0 110-1.5h1.75v-2h-8a1 1 0 00-.714 1.7.75.75 0 01-1.072 1.05A2.495 2.495 0 012 11.5v-9zm10.5-1V9h-8c-.356 0-.694.074-1 .208V2.5a1 1 0 011-1h8zM5 12.25v3.25a.25.25 0 00.4.2l1.45-1.087a.25.25 0 01.3 0L8.6 15.7a.25.25 0 00.4-.2v-3.25a.25.25 0 00-.25-.25h-3.5a.25.25 0 00-.25.25z"></path></svg>
                  <span class="text-sm font-medium text-gray-900"><%= @project.settings['github_repo'] || 'Not set' %></span>
                </div>
              </div>
              <div>
                <label class="block text-xs font-medium text-gray-500 uppercase tracking-wide mb-1">Installation ID</label>
                <span class="text-sm font-mono text-gray-600"><%= @project.settings['github_installation_id'] %></span>
              </div>
            </div>
          </div>

          <!-- Branch Settings Form -->
          <%= form_with(model: @project, url: project_settings_path(@project), method: :patch, local: true, class: "mt-4") do |form| %>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Source Branch (fork from)</label>
                <%= form.text_field :github_source_branch, 
                    value: @project.settings['github_source_branch'], 
                    placeholder: "main",
                    class: "block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-blue-500 focus:border-blue-500 sm:text-sm" %>
                <p class="text-xs text-gray-500 mt-1">Branch to create new PR branches from (e.g., staging, develop)</p>
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Target Branch (merge to)</label>
                <%= form.text_field :github_base_branch, 
                    value: @project.settings['github_base_branch'], 
                    placeholder: "main",
                    class: "block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-blue-500 focus:border-blue-500 sm:text-sm" %>
                <p class="text-xs text-gray-500 mt-1">Branch where PRs will be merged (default: main)</p>
              </div>
            </div>
            <div class="flex items-center justify-between mt-4 pt-4 border-t border-gray-200">
              <div class="flex items-center space-x-3">
                <%= form.submit "Save Branch Settings",
                      class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500" %>
                <a href="<%= Github::InstallationService.app_install_url(project_id: @project.id) %>"
                   class="inline-flex items-center px-3 py-2 border border-gray-300 text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50">
                  <svg viewBox="0 0 16 16" width="14" height="14" class="mr-1.5" aria-hidden="true"><path fill="currentColor" d="M11.013 1.427a1.75 1.75 0 012.474 0l1.086 1.086a1.75 1.75 0 010 2.474l-8.61 8.61c-.21.21-.47.364-.756.445l-3.251.93a.75.75 0 01-.927-.928l.929-3.25a1.75 1.75 0 01.445-.758l8.61-8.61zm1.414 1.06a.25.25 0 00-.354 0L10.811 3.75l1.439 1.44 1.263-1.263a.25.25 0 000-.354l-1.086-1.086zM11.189 6.25L9.75 4.81l-6.286 6.287a.25.25 0 00-.064.108l-.558 1.953 1.953-.558a.249.249 0 00.108-.064l6.286-6.286z"></path></svg>
                  Reconfigure App
                </a>
              </div>
              <p class="text-xs text-gray-500">
                PRs will be created as drafts when you click "Create PR" on errors.
              </p>
            </div>
          <% end %>

          <!-- Disconnect GitHub - separate from the form above -->
          <div class="mt-6 pt-6 border-t border-gray-200">
            <div class="flex items-center justify-between">
              <div>
                <h4 class="text-sm font-medium text-gray-900">Disconnect Repository</h4>
                <p class="text-sm text-gray-500">Remove the GitHub connection from this project</p>
              </div>
              <%= button_to "Disconnect Repository",
                    disconnect_github_project_settings_path(@project),
                    method: :delete,
                    data: { turbo_confirm: "Are you sure you want to disconnect this GitHub repository?\n\nThis will:\n• Remove the repository connection\n• Clear all branch settings\n• Remove all PR URL references\n\nYou can reconnect at any time." },
                    class: "inline-flex items-center px-3 py-2 border border-red-300 text-sm font-medium rounded-md text-red-700 bg-white hover:bg-red-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500" %>
            </div>
          </div>
        </div>
      <% else %>
        <!-- Not Connected State -->
        <div class="space-y-6">
          <!-- Install new GitHub App - always shown -->
          <div class="text-center py-4">
            <div class="mx-auto w-16 h-16 bg-gray-100 rounded-full flex items-center justify-center mb-4">
              <svg viewBox="0 0 16 16" width="32" height="32" class="text-gray-400" aria-hidden="true"><path fill="currentColor" d="M8 0C3.58 0 0 3.58 0 8a8 8 0 005.47 7.59c.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82a7.5 7.5 0 012 0c1.53-1.03 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0016 8c0-4.42-3.58-8-8-8z"></path></svg>
            </div>
            <h4 class="text-base font-medium text-gray-900 mb-2">Connect your GitHub repository</h4>
            <p class="text-sm text-gray-500 mb-6 max-w-md mx-auto">
              Install the ActiveRabbit GitHub App to enable automatic PR creation with AI-generated fixes for your errors.
            </p>
            <a href="<%= Github::InstallationService.app_install_url(project_id: @project.id) %>"
              class="inline-flex items-center px-5 py-2.5 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-gray-900 hover:bg-gray-800 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-gray-500">
              <svg viewBox="0 0 16 16" width="18" height="18" class="mr-2" aria-hidden="true"><path fill="currentColor" d="M8 0C3.58 0 0 3.58 0 8a8 8 0 005.47 7.59c.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82a7.5 7.5 0 012 0c1.53-1.03 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0016 8c0-4.42-3.58-8-8-8z"></path></svg>
              Install GitHub App
            </a>
            <p class="text-xs text-gray-400 mt-4">
              Required permissions: <strong>Pull requests</strong> (read/write) and <strong>Contents</strong> (read)
            </p>
          </div>

          <% if @github_connected_projects.present? %>
            <div class="relative">
              <div class="absolute inset-0 flex items-center">
                <div class="w-full border-t border-gray-300"></div>
              </div>
              <div class="relative flex justify-center text-sm">
                <span class="px-2 bg-white text-gray-500">or connect existing repository</span>
              </div>
            </div>

            <!-- Option 2: Use existing installation from another project -->
            <div class="bg-gray-50 rounded-lg p-4 border border-gray-200">
              <h4 class="text-sm font-medium text-gray-900 mb-2">Use existing GitHub connection</h4>
              <p class="text-xs text-gray-700 mb-3">
                You have GitHub connected to other projects. You can use the same repository for this project.
              </p>
              <%= form_with(model: @project, url: project_settings_path(@project), method: :patch, local: true) do |form| %>
                <div class="flex items-end gap-3">
                  <div class="flex-1">
                    <label class="block text-xs font-medium text-gray-800 mb-1">Copy settings from:</label>
                    <%= form.select :copy_github_from_project_id,
                        @github_connected_projects.map { |p| ["#{p.name} (#{p.settings['github_repo']})", p.id] },
                        { include_blank: "Select a project..." },
                        class: "block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-gray-500 focus:border-gray-500 sm:text-sm bg-white" %>
                  </div>
                  <%= form.button :submit,
                    class: "inline-flex items-center px-5 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-gray-900 hover:bg-gray-800 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-gray-500" do %>

                    <svg viewBox="0 0 16 16" width="16" height="16" aria-hidden="true" class="shrink-0 mr-1">
                      <path fill="currentColor"
                        d="M8 0C3.58 0 0 3.58 0 8a8 8 0 005.47 7.59c.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82a7.5 7.5 0 012 0c1.53-1.03 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0016 8c0-4.42-3.58-8-8-8z" />
                    </svg>

                    Use This Connection
                  <% end %>
                </div>
              <% end %>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>

  <!-- Slack Integration & Notification Settings Form -->
  <%= form_with model: @project,
              url: project_settings_path(@project),
              method: :put,
              local: true do |f| %>

    <div id="slack-integration" class="bg-white rounded-xl shadow-sm border border-gray-200 mb-10 overflow-hidden mb-4">
      <div class="px-6 py-5 bg-gradient-to-r from-purple-50 to-white border-b border-gray-100">
        <div class="flex items-center justify-between">
          <div class="flex items-center">
            <div class="flex-shrink-0 w-10 h-10 bg-purple-100 rounded-lg flex items-center justify-center">
              <svg class="w-5 h-5 text-purple-600" fill="currentColor" viewBox="0 0 24 24">
                <path d="M5.042 15.165a2.528 2.528 0 0 1-2.52-2.523c0-1.393 1.135-2.524 2.52-2.524h2.52v2.524c0 1.393-1.127 2.523-2.52 2.523zm0 0c-1.393 0-2.52 1.135-2.52 2.523v2.52c0 1.393 1.127 2.524 2.52 2.524 1.393 0 2.523-1.131 2.523-2.524v-2.52c0-1.388-1.13-2.523-2.523-2.523zm7.12-7.12a2.528 2.528 0 0 1-2.523-2.52c0-1.393 1.135-2.524 2.523-2.524 1.393 0 2.524 1.131 2.524 2.524v2.52c0 1.393-1.131 2.52-2.524 2.52zm0 0c1.393 0 2.524 1.127 2.524 2.52v2.523c0 1.393-1.131 2.524-2.524 2.524-1.388 0-2.523-1.131-2.523-2.524V15.685c0-1.393 1.135-2.52 2.523-2.52z"/>
              </svg>
            </div>
            <div class="ml-4">
              <h3 class="text-lg font-semibold text-gray-900">Slack Integration</h3>
              <p class="text-sm text-gray-500">Get real-time notifications in your Slack workspace</p>
            </div>
          </div>
          <div class="flex items-center">
            <% if @project.slack_configured? %>
              <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
                <svg class="w-4 h-4 mr-1" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
                </svg>
                Configured
              </span>
            <% else %>
              <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-yellow-100 text-yellow-800">
                <svg class="w-4 h-4 mr-1" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd"></path>
                </svg>
                Not Configured
              </span>
            <% end %>
          </div>
        </div>
      </div>

      <div class="p-6">
        <!-- Enable Slack Button -->
        <% if @project.slack_access_token.present? %>
          <div class="p-4 bg-green-100 border border-green-300 rounded">
            <p>Slack connected successfully to <b><%= @project.slack_team_name %></b></p>
          </div>
        <% else %>
          <a href="/slack/oauth/authorize?project_id=<%= @project.id %>">
            <img alt="Add to Slack" height="40" width="139"
              src="https://platform.slack-edge.com/img/add_to_slack.png"
              srcset="https://platform.slack-edge.com/img/add_to_slack.png 1x,
                      https://platform.slack-edge.com/img/add_to_slack@2x.png 2x" />
          </a>
        <% end %>
      </div>

      <div class="px-6 py-5">
        <fieldset class="space-y-6" data-controller="notifications">

          <!-- Master switch -->
          <div class="flex items-center justify-between">
            <div>
              <label class="text-sm font-medium text-gray-900">
                Enable notifications
              </label>
              <p class="text-sm text-gray-500">
                Turn all alerts on or off for this project
              </p>
            </div>

            <label class="relative inline-flex items-center cursor-pointer">
              <input type="hidden"
                    name="project[notifications][enabled]"
                    value="0">

              <input type="checkbox"
                    name="project[notifications][enabled]"
                    value="1"
                    class="sr-only peer"
                    data-action="notifications#toggle"
                    data-notifications-target="master"
                    <%= "checked" if @project.notifications_enabled? %>>
              <div class="w-11 h-6 bg-gray-200 peer-focus:outline-none rounded-full peer
                          peer-checked:bg-indigo-600
                          after:content-[''] after:absolute after:top-[2px] after:left-[2px]
                          after:bg-white after:border-gray-300 after:border after:rounded-full
                          after:h-5 after:w-5 after:transition-all
                          peer-checked:after:translate-x-full">
              </div>
            </label>
          </div>

          <!-- Channels -->
          <div class="space-y-4 pl-1 <%= 'opacity-50 pointer-events-none' unless @project.notifications_enabled? %>">
            <p class="text-sm font-medium text-gray-900">
              Delivery channels
            </p>

            <!-- Slack -->
            <div class="flex items-start justify-between">
              <div>
                <label class="text-sm font-medium text-gray-900">
                  Slack
                </label>
                <p class="text-sm text-gray-500">
                  Send alerts to your Slack workspace
                </p>

                <% unless @project.slack_configured? %>
                  <p class="text-xs text-yellow-600 mt-1">
                    Slack is not connected yet
                  </p>
                <% end %>
              </div>

              <input type="checkbox"
                name="project[notifications][channels][slack]"
                value="1"
                class="h-4 w-4 text-indigo-600 border-gray-300 rounded focus:ring-indigo-500"
                data-notifications-target="channel"
                <%= "checked" if @project.notify_via_slack? %>
                <%= "disabled" unless @project.slack_configured? %>>
            </div>

            <!-- Discord -->
            <div class="flex items-start justify-between">
              <div>
                <label class="text-sm font-medium text-gray-900">
                  Discord
                </label>
                <p class="text-sm text-gray-500">
                  Send alerts to your Discord channel via webhook
                </p>

                <% unless @project.discord_configured? %>
                  <p class="text-xs text-yellow-600 mt-1">
                    Discord webhook is not configured yet
                  </p>
                <% end %>
              </div>

              <input type="checkbox"
                name="project[notifications][channels][discord]"
                value="1"
                class="h-4 w-4 text-indigo-600 border-gray-300 rounded focus:ring-indigo-500"
                data-notifications-target="channel"
                <%= "checked" if @project.notify_via_discord? %>
                <%= "disabled" unless @project.discord_configured? %>>
            </div>

            <!-- Email -->
            <div class="flex items-start justify-between">
              <div>
                <label class="text-sm font-medium text-gray-900">
                  Email
                </label>
                <p class="text-sm text-gray-500">
                  Send alerts to project owner email
                </p>
              </div>

              <input type="checkbox"
                name="project[notifications][channels][email]"
                value="1"
                class="h-4 w-4 text-indigo-600 border-gray-300 rounded focus:ring-indigo-500"
                data-notifications-target="channel"
                <%= "checked" if @project.notify_via_email? %>>
            </div>
          </div>
        </fieldset>
        <div class="mt-6 flex items-center justify-between">
          <% if @project.slack_configured? && @project.notify_via_slack? %>
            <button type="button"
                    onclick="testSlackNotification()"
                    class="inline-flex items-center px-4 py-2 border border-gray-300 text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-purple-500">
              <svg class="w-4 h-4 mr-2 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"></path>
              </svg>
              Test Slack Notification
            </button>
          <% else %>
            <div></div>
          <% end %>

          <button type="submit"
                  class="inline-flex items-center px-4 py-2 rounded-md
                        bg-indigo-600 text-white text-sm font-medium
                        hover:bg-indigo-700
                        focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500">
            Save notification settings
          </button>
        </div>
      </div>
    </div>
  <% end %>

  <!-- Discord Integration Card -->
  <div id="discord-integration" class="bg-white rounded-xl shadow-sm border border-gray-200 mb-10 overflow-hidden mb-4">
    <div class="px-6 py-5 bg-gradient-to-r from-indigo-50 to-white border-b border-gray-100">
      <div class="flex items-center justify-between">
        <div class="flex items-center">
          <div class="flex-shrink-0 w-10 h-10 bg-indigo-100 rounded-lg flex items-center justify-center">
            <svg class="w-5 h-5 text-indigo-600" viewBox="0 0 24 24" fill="currentColor">
              <path d="M20.317 4.3698a19.7913 19.7913 0 00-4.8851-1.5152.0741.0741 0 00-.0785.0371c-.211.3753-.4447.8648-.6083 1.2495-1.8447-.2762-3.68-.2762-5.4868 0-.1636-.3933-.4058-.8742-.6177-1.2495a.077.077 0 00-.0785-.037 19.7363 19.7363 0 00-4.8852 1.515.0699.0699 0 00-.0321.0277C.5334 9.0458-.319 13.5799.0992 18.0578a.0824.0824 0 00.0312.0561c2.0528 1.5076 4.0413 2.4228 5.9929 3.0294a.0777.0777 0 00.0842-.0276c.4616-.6304.8731-1.2952 1.226-1.9942a.076.076 0 00-.0416-.1057c-.6528-.2476-1.2743-.5495-1.8722-.8923a.077.077 0 01-.0076-.1277c.1258-.0943.2517-.1923.3718-.2914a.0743.0743 0 01.0776-.0105c3.9278 1.7933 8.18 1.7933 12.0614 0a.0739.0739 0 01.0785.0095c.1202.099.246.1981.3728.2924a.077.077 0 01-.0066.1276 12.2986 12.2986 0 01-1.873.8914.0766.0766 0 00-.0407.1067c.3604.698.7719 1.3628 1.225 1.9932a.076.076 0 00.0842.0286c1.961-.6067 3.9495-1.5219 6.0023-3.0294a.077.077 0 00.0313-.0552c.5004-5.177-.8382-9.6739-3.5485-13.6604a.061.061 0 00-.0312-.0286z"/>
            </svg>
          </div>
          <div class="ml-4">
            <h3 class="text-lg font-semibold text-gray-900">Discord Integration</h3>
            <p class="text-sm text-gray-500">Get real-time notifications in your Discord server</p>
          </div>
        </div>
        <div class="flex items-center">
          <% if @project.discord_configured? %>
            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
              <svg class="w-4 h-4 mr-1" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
              </svg>
              Connected
            </span>
          <% else %>
            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-yellow-100 text-yellow-800">
              <svg class="w-4 h-4 mr-1" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd"></path>
              </svg>
              Not Connected
            </span>
          <% end %>
        </div>
      </div>
    </div>

    <div class="p-6">
      <% if @project.discord_configured? %>
        <div class="p-4 bg-green-50 border border-green-200 rounded-lg mb-4">
          <div class="flex items-center">
            <svg class="w-5 h-5 text-green-500 mr-2" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
            </svg>
            <div>
              <p class="text-sm font-medium text-green-800">
                Discord connected
                <% if @project.discord_guild_name.present? %>
                  to <b><%= @project.discord_guild_name %></b>
                <% end %>
              </p>
            </div>
          </div>
        </div>

        <div class="flex items-center justify-between">
          <div class="flex items-center space-x-3">
            <% if @project.notify_via_discord? %>
              <button type="button"
                      onclick="testDiscordNotification()"
                      class="inline-flex items-center px-4 py-2 border border-gray-300 text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500">
                <svg class="w-4 h-4 mr-2 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"></path>
                </svg>
                Test Discord Notification
              </button>
            <% end %>

            <a href="/discord/oauth/authorize?project_id=<%= @project.id %>"
               class="inline-flex items-center px-4 py-2 border border-gray-300 text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500">
              <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path>
              </svg>
              Reconnect
            </a>
          </div>

          <%= button_to "Disconnect Discord",
                disconnect_discord_project_settings_path(@project),
                method: :delete,
                data: { turbo_confirm: "Are you sure you want to disconnect Discord?\n\nYou can reconnect at any time." },
                class: "inline-flex items-center px-3 py-2 border border-red-300 text-sm font-medium rounded-md text-red-700 bg-white hover:bg-red-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500" %>
        </div>
      <% else %>
        <div class="text-center py-6">
