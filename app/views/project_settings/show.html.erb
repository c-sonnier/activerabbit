        </div>
      </div>

      <div class="p-6 space-y-6">
        <!-- Master toggle -->
        <div class="flex items-center justify-between">
          <div>
            <label class="text-sm font-medium text-gray-900">Enable auto AI summary</label>
            <p class="text-sm text-gray-500">
              Automatically generate AI root-cause analysis when new errors are detected
            </p>
          </div>
          <label class="relative inline-flex items-center cursor-pointer">
            <input type="hidden"
                   name="project[auto_ai_summary][enabled]"
                   value="0">
            <input type="checkbox"
                   name="project[auto_ai_summary][enabled]"
                   value="1"
                   class="sr-only peer"
                   data-auto-ai-summary-target="master"
                   data-action="auto-ai-summary#toggle"
                   <%= "checked" if @project.auto_ai_summary_enabled? %>>
            <div class="w-11 h-6 bg-gray-200 peer-focus:outline-none rounded-full peer
                        peer-checked:bg-violet-600
                        after:content-[''] after:absolute after:top-[2px] after:left-[2px]
                        after:bg-white after:border-gray-300 after:border after:rounded-full
                        after:h-5 after:w-5 after:transition-all
                        peer-checked:after:translate-x-full">
            </div>
          </label>
        </div>

        <!-- Severity level selection -->
        <div data-auto-ai-summary-target="severityGroup"
             class="<%= 'opacity-50 pointer-events-none' unless @project.auto_ai_summary_enabled? %>">
          <div class="border-t border-gray-200 pt-5">
            <p class="text-sm font-medium text-gray-900 mb-1">Severity levels</p>
            <p class="text-sm text-gray-500 mb-4">
              Select which error severity levels should trigger auto AI summary
            </p>

            <% selected_levels = @project.auto_ai_summary_severity_levels %>
            <div class="space-y-4">
              <% [
                ["critical", "Critical", "Crashes, infrastructure failures, security issues", "red"],
                ["high",     "High",     "Request failures, 500 errors, timeouts", "orange"],
                ["medium",   "Medium",   "Partial failures, validation errors", "yellow"],
                ["low",      "Low",      "Routing errors, cosmetic issues", "gray"]
              ].each do |value, label, description, color| %>
                <div class="flex items-center justify-between">
                  <div class="flex items-center">
                    <span class="inline-block w-2.5 h-2.5 rounded-full mr-3
                                 <%= case color
                                     when 'red' then 'bg-red-500'
                                     when 'orange' then 'bg-orange-500'
                                     when 'yellow' then 'bg-yellow-500'
                                     else 'bg-gray-400'
                                     end %>"></span>
                    <div>
                      <label class="text-sm font-medium text-gray-900"><%= label %></label>
                      <p class="text-sm text-gray-500"><%= description %></p>
                    </div>
                  </div>
                  <label class="relative inline-flex items-center cursor-pointer">
                    <input type="hidden"
                           name="project[auto_ai_summary][severity_levels][]"
                           value="">
                    <input type="checkbox"
                           name="project[auto_ai_summary][severity_levels][]"
                           value="<%= value %>"
                           class="sr-only peer"
                           data-auto-ai-summary-target="severity"
                           <%= "checked" if selected_levels.include?(value) %>>
                    <div class="w-11 h-6 bg-gray-200 peer-focus:outline-none rounded-full peer
                                peer-checked:bg-violet-600
                                after:content-[''] after:absolute after:top-[2px] after:left-[2px]
                                after:bg-white after:border-gray-300 after:border after:rounded-full
                                after:h-5 after:w-5 after:transition-all
                                peer-checked:after:translate-x-full">
                    </div>
                  </label>
                </div>
              <% end %>
            </div>
          </div>
        </div>

        <div class="flex items-center justify-between pt-4 border-t border-gray-100">
          <p class="text-xs text-gray-400">
