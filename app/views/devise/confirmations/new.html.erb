<% content_for :title, "Resend Confirmation" %>
<% content_for :page_title, "Confirm your email" %>
<% content_for :page_subtitle, "Enter your email and we'll resend the confirmation link" %>
<% content_for :layout, "auth" %>

<div class="mt-2 mb-6 flex justify-center">
  <div class="w-16 h-16 rounded-full bg-gray-900 border border-gray-800 flex items-center justify-center">
    <svg class="w-8 h-8 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
    </svg>
  </div>
</div>

<%= form_for(resource, as: resource_name, url: confirmation_path(resource_name), html: { method: :post, class: "space-y-5" }) do |f| %>
  <% if resource.errors.any? %>
    <div class="rounded-xl bg-red-950/50 p-4 border border-red-800">
      <div class="flex">
        <div class="flex-shrink-0">
          <svg class="h-5 w-5 text-red-400" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" />
          </svg>
        </div>
        <div class="ml-3">
          <div class="text-sm text-red-400/80">
            <ul class="list-disc pl-5 space-y-1">
              <% resource.errors.full_messages.each do |message| %>
                <li><%= message %></li>
              <% end %>
            </ul>
          </div>
        </div>
      </div>
    </div>
  <% end %>

  <div>
    <%= f.label :email, class: "block text-sm font-medium text-gray-400 mb-2" %>
    <%= f.email_field :email,
          autofocus: true,
          autocomplete: "email",
          placeholder: "you@example.com",
          value: (resource.pending_reconfirmation? ? resource.unconfirmed_email : resource.email),
          class: "block w-full px-4 py-3 bg-gray-900 border border-gray-800 rounded-xl text-white placeholder-gray-600 focus:outline-none focus:ring-2 focus:ring-gray-700 focus:border-gray-700 transition duration-200" %>
  </div>

  <div>
    <%= f.submit "Resend confirmation email",
          class: "w-full flex justify-center py-3 px-4 text-sm font-semibold rounded-xl text-gray-950 bg-white hover:bg-gray-200 focus:outline-none focus:ring-2 focus:ring-gray-700 transition duration-200 cursor-pointer" %>
  </div>
<% end %>

<div class="mt-4 text-center text-xs text-gray-500">
  Check your spam folder if you don't see the email within a few minutes.
</div>

<!-- Links -->
<div class="mt-8 text-center space-y-2">
  <div>
    <span class="text-sm text-gray-500">Already confirmed?</span>
    <%= link_to "Sign in", new_session_path(resource_name),
          class: "text-sm font-semibold text-white hover:text-gray-300 transition-colors ml-1" %>
  </div>
  <div>
    <%= link_to "Create a new account", new_registration_path(resource_name),
          class: "text-sm text-gray-400 hover:text-white transition-colors" %>
  </div>
</div>
