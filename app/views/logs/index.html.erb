<% content_for :page_title do %>
  Logs
<% end %>

<div class="space-y-4 pb-20" data-controller="log-search log-stream" data-log-stream-project-id-value="<%= @project&.id || '' %>">
  <!-- Search & Filters -->
  <div class="bg-white shadow-lg px-6 py-3 fixed bottom-0 right-0 z-40 border-t border-gray-200" style="left: 0;" id="logs-search-bar">
    <div class="flex items-center gap-4">
      <span class="text-xs text-gray-400 whitespace-nowrap"><%= number_with_delimiter(@total_count) %> logs</span>
      <%= form_tag(request.path, method: :get, class: "flex-1 flex items-center gap-3", data: { "log-search-target": "form" }) do %>
        <div class="flex-1 relative">
          <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
          </svg>
          <input type="text" name="q" value="<%= params[:q] %>" placeholder="Search logs... (e.g. level:error source:StripeService payment)"
                 class="w-full pl-10 pr-4 py-2 border border-gray-300 rounded-lg text-sm focus:ring-indigo-500 focus:border-indigo-500"
                 data-log-search-target="query"
                 data-action="keydown.enter->log-search#search">
        </div>

        <select name="level" class="border border-gray-300 rounded-lg text-sm py-2 px-3 focus:ring-indigo-500 focus:border-indigo-500" data-action="change->log-search#search">
          <option value="">All Levels</option>
          <% LogEntry::LEVELS.each do |name, _value| %>
            <option value="<%= name %>" <%= 'selected' if params[:level] == name.to_s %>><%= name.to_s.upcase %></option>
          <% end %>
        </select>

        <select name="range" class="border border-gray-300 rounded-lg text-sm py-2 px-3 focus:ring-indigo-500 focus:border-indigo-500" data-action="change->log-search#search">
          <option value="1h" <%= 'selected' if params[:range] == '1h' %>>Last 1h</option>
          <option value="6h" <%= 'selected' if params[:range] == '6h' %>>Last 6h</option>
          <option value="24h" <%= 'selected' if params[:range] == '24h' || params[:range].blank? %>>Last 24h</option>
          <option value="7d" <%= 'selected' if params[:range] == '7d' %>>Last 7d</option>
          <option value="30d" <%= 'selected' if params[:range] == '30d' %>>Last 30d</option>
        </select>

        <button type="submit" class="px-4 py-2 bg-indigo-600 text-white text-sm rounded-lg hover:bg-indigo-700">
          Search
        </button>
      <% end %>

      <!-- Live tail toggle -->
      <% if @project %>
        <button class="flex items-center gap-2 px-3 py-2 text-sm border rounded-lg transition-colors"
                data-log-stream-target="toggleBtn"
                data-action="click->log-stream#toggle"
                data-log-stream-active="false">
          <span class="w-2 h-2 rounded-full bg-gray-400" data-log-stream-target="indicator"></span>
          <span data-log-stream-target="label">Live Tail</span>
        </button>
      <% end %>
    </div>
  </div>

  <!-- Log entries -->
  <div class="bg-white rounded-lg shadow">
    <div class="px-6 py-4 border-b border-gray-200 flex justify-between items-center">
      <h3 class="text-lg font-medium text-gray-900">Log Entries</h3>
      <%= link_to onboarding_install_gem_path(project_id: @project.id), class: "bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-md text-sm font-medium" do %>
        Install SDK
      <% end %>
    </div>
    <div class="overflow-hidden">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider w-4"></th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Timestamp</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Level</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Source</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Message</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Trace</th>
          </tr>
        </thead>
        <tbody id="log-entries" class="bg-white divide-y divide-gray-200" data-log-stream-target="entries">
          <% if @logs.any? %>
            <% @logs.each do |log_entry| %>
              <%= render "logs/log_entry_row", log_entry: log_entry %>
            <% end %>
          <% else %>
            <tr>
              <td colspan="6" class="px-6 py-12">
                <div class="max-w-2xl mx-auto">
                  <div class="text-center mb-8">
                    <svg class="mx-auto h-12 w-12 text-gray-400 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
                    </svg>
                    <h3 class="text-lg font-medium text-gray-900 mb-1">No log entries yet</h3>
                    <p class="text-sm text-gray-500">Choose one of the methods below to start sending logs.</p>
                  </div>

                  <!-- Tabs -->
                  <div class="flex gap-2 mb-4 justify-center" id="log-example-tabs">
                    <button onclick="switchLogExample('rails')" id="log-ex-tab-rails"
                            class="log-ex-tab px-4 py-1.5 text-sm font-medium rounded-md bg-indigo-600 text-white">
                      Rails SDK
                    </button>
                    <button onclick="switchLogExample('curl')" id="log-ex-tab-curl"
                            class="log-ex-tab px-4 py-1.5 text-sm font-medium rounded-md bg-gray-100 text-gray-600 hover:bg-gray-200">
                      cURL
                    </button>
                    <button onclick="switchLogExample('ruby')" id="log-ex-tab-ruby"
                            class="log-ex-tab px-4 py-1.5 text-sm font-medium rounded-md bg-gray-100 text-gray-600 hover:bg-gray-200">
                      Ruby
                    </button>
                    <button onclick="switchLogExample('node')" id="log-ex-tab-node"
                            class="log-ex-tab px-4 py-1.5 text-sm font-medium rounded-md bg-gray-100 text-gray-600 hover:bg-gray-200">
                      Node.js
                    </button>
                  </div>

                  <!-- Rails SDK panel -->
                  <div id="log-ex-panel-rails" class="log-ex-panel">
                    <p class="text-sm text-gray-600 mb-3">Add <code class="bg-gray-100 px-1.5 py-0.5 rounded text-xs">enable_logs</code> to your initializer &mdash; every <code class="bg-gray-100 px-1.5 py-0.5 rounded text-xs">Rails.logger</code> call is forwarded automatically.</p>
                    <div class="bg-gray-900 rounded-lg p-4 text-left">
<pre class="text-green-400 text-sm whitespace-pre-wrap"><code><span class="text-gray-500"># config/initializers/activerabbit.rb</span>
ActiveRabbit::Client.configure do |config|
  config.api_key     = ENV["ACTIVERABBIT_API_KEY"]
  config.enable_logs = true
end

<span class="text-gray-500"># That's it! All Rails.logger calls are now forwarded:</span>
Rails.logger.info "Order created"
Rails.logger.warn "Slow query detected"
Rails.logger.error "Payment failed"</code></pre>
                    </div>
                  </div>

                  <!-- cURL panel -->
                  <div id="log-ex-panel-curl" class="log-ex-panel hidden">
                    <p class="text-sm text-gray-600 mb-3">Send structured log entries from any platform using a simple POST request.</p>
                    <div class="bg-gray-900 rounded-lg p-4 text-left">
<pre class="text-green-400 text-sm whitespace-pre-wrap"><code>curl -X POST <%= request.base_url %>/api/v1/logs \
  -H "Content-Type: application/json" \
  -H "X-Project-Token: <span class="text-yellow-300"><%= @project&.api_token || 'YOUR_PROJECT_TOKEN' %></span>" \
  -d '{
    "entries": [
      {
        "level": "info",
        "message": "User signed in",
        "source": "AuthController",
        "environment": "production"
      },
      {
        "level": "error",
        "message": "Payment gateway timeout",
        "source": "PaymentService",
        "trace_id": "tr_abc123"
      }
    ]
  }'</code></pre>
                    </div>
                  </div>

                  <!-- Ruby panel -->
                  <div id="log-ex-panel-ruby" class="log-ex-panel hidden">
                    <p class="text-sm text-gray-600 mb-3">Send logs from any Ruby app using <code class="bg-gray-100 px-1.5 py-0.5 rounded text-xs">Net::HTTP</code>.</p>
                    <div class="bg-gray-900 rounded-lg p-4 text-left">
<pre class="text-green-400 text-sm whitespace-pre-wrap"><code>require "net/http"
require "json"

uri = URI("<%= request.base_url %>/api/v1/logs")
http = Net::HTTP.new(uri.host, uri.port)

request = Net::HTTP::Post.new(uri)
request["Content-Type"] = "application/json"
request["X-Project-Token"] = "<span class="text-yellow-300"><%= @project&.api_token || 'YOUR_PROJECT_TOKEN' %></span>"
request.body = {
  entries: [
    { level: "info",  message: "Job started",  source: "ImportJob" },
    { level: "error", message: "CSV parse failed", source: "ImportJob" }
  ]
}.to_json

response = http.request(request)
puts response.body</code></pre>
                    </div>
                  </div>

                  <!-- Node.js panel -->
                  <div id="log-ex-panel-node" class="log-ex-panel hidden">
                    <p class="text-sm text-gray-600 mb-3">Send logs from Node.js using <code class="bg-gray-100 px-1.5 py-0.5 rounded text-xs">fetch</code>.</p>
                    <div class="bg-gray-900 rounded-lg p-4 text-left">
<pre class="text-green-400 text-sm whitespace-pre-wrap"><code>const response = await fetch("<%= request.base_url %>/api/v1/logs", {
  method: "POST",
  headers: {
    "Content-Type": "application/json",
    "X-Project-Token": "<span class="text-yellow-300"><%= @project&.api_token || 'YOUR_PROJECT_TOKEN' %></span>"
  },
  body: JSON.stringify({
    entries: [
      { level: "info",  message: "Server started", source: "app" },
      { level: "warn",  message: "Memory usage high", source: "monitor" },
      { level: "error", message: "Unhandled rejection", source: "api" }
    ]
  })
});

console.log(await response.json());</code></pre>
                    </div>
                  </div>

                  <% if @project %>
                    <div class="mt-4 text-center">
                      <%= link_to onboarding_install_gem_path(project_id: @project.id),
                                  class: "text-sm text-indigo-600 hover:text-indigo-800 font-medium" do %>
                        View full setup guide &rarr;
                      <% end %>
                    </div>
                  <% end %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
    <!-- Loading indicator for infinite scroll -->
    <div class="hidden px-6 py-4 border-t border-gray-200 text-center" data-log-stream-target="loader">
      <div class="inline-flex items-center gap-2 text-sm text-gray-500">
        <span class="flex gap-1">
          <span class="w-1.5 h-1.5 bg-gray-400 rounded-full animate-bounce" style="animation-delay: 0ms"></span>
          <span class="w-1.5 h-1.5 bg-gray-400 rounded-full animate-bounce" style="animation-delay: 150ms"></span>
          <span class="w-1.5 h-1.5 bg-gray-400 rounded-full animate-bounce" style="animation-delay: 300ms"></span>
        </span>
        Loading more logs
      </div>
    </div>

    <% if @logs.respond_to?(:total_pages) && @logs.total_pages > 1 %>
      <div class="px-6 py-4 border-t border-gray-200" data-log-stream-target="pagination">
        <%= paginate @logs %>
      </div>
    <% end %>
  </div>
</div>

<script>
(function() {
  var bar = document.getElementById('logs-search-bar');
  var content = document.querySelector('[data-sidebar-target="content"]');
  if (!bar || !content) return;
  function sync() {
    bar.style.left = content.getBoundingClientRect().left + 'px';
  }
  sync();
  var observer = new MutationObserver(sync);
  observer.observe(document.documentElement, { attributes: true, attributeFilter: ['class'] });
  window.addEventListener('resize', sync);
})();

function switchLogExample(method) {
  document.querySelectorAll('.log-ex-panel').forEach(function(p) { p.classList.add('hidden'); });
  document.querySelectorAll('.log-ex-tab').forEach(function(t) {
    t.classList.remove('bg-indigo-600', 'text-white');
    t.classList.add('bg-gray-100', 'text-gray-600');
  });
  var panel = document.getElementById('log-ex-panel-' + method);
  if (panel) panel.classList.remove('hidden');
  var tab = document.getElementById('log-ex-tab-' + method);
  if (tab) {
    tab.classList.remove('bg-gray-100', 'text-gray-600');
    tab.classList.add('bg-indigo-600', 'text-white');
  }
}
</script>
