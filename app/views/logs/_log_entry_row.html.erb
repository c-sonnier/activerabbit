<%
  level_colors = {
    "trace" => "bg-gray-100 text-gray-700",
    "debug" => "bg-gray-100 text-gray-700",
    "info"  => "bg-blue-100 text-blue-700",
    "warn"  => "bg-yellow-100 text-yellow-800",
    "error" => "bg-red-100 text-red-800",
    "fatal" => "bg-red-200 text-red-900"
  }
  level_dot_colors = {
    "trace" => "bg-gray-400",
    "debug" => "bg-gray-400",
    "info"  => "bg-blue-400",
    "warn"  => "bg-yellow-400",
    "error" => "bg-red-400",
    "fatal" => "bg-red-600"
  }
  level = log_entry.level_name || "info"
%>

<div class="group px-4 py-3 hover:bg-gray-50 cursor-pointer transition-colors"
     data-action="click->log-search#toggleDetail"
     data-log-entry-id="<%= log_entry.id %>">
  <div class="flex items-start gap-3">
    <!-- Level indicator -->
    <div class="flex-shrink-0 mt-1.5">
      <div class="w-2 h-2 rounded-full <%= level_dot_colors[level] || 'bg-gray-400' %>"></div>
    </div>

    <!-- Timestamp -->
    <div class="flex-shrink-0 w-44 text-xs text-gray-500 font-mono mt-0.5">
      <%= log_entry.occurred_at.strftime("%Y-%m-%d %H:%M:%S.%L") %>
    </div>

    <!-- Level badge -->
    <div class="flex-shrink-0">
      <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium <%= level_colors[level] || 'bg-gray-100 text-gray-700' %>">
        <%= level.upcase %>
      </span>
    </div>

    <!-- Source -->
    <% if log_entry.source.present? %>
      <div class="flex-shrink-0 text-xs text-gray-500 font-mono">
        <%= log_entry.source %>
      </div>
    <% end %>

    <!-- Message -->
    <div class="flex-1 min-w-0">
      <p class="text-sm text-gray-900 truncate font-mono"><%= log_entry.message %></p>
    </div>

    <!-- Trace link -->
    <% if log_entry.trace_id.present? %>
      <div class="flex-shrink-0">
        <span class="text-xs text-indigo-600 font-mono"><%= log_entry.trace_id.truncate(12) %></span>
      </div>
    <% end %>
  </div>

  <!-- Expandable detail (hidden by default) -->
  <div class="hidden mt-3 ml-5 pl-4 border-l-2 border-gray-200" data-log-search-target="detail" data-log-detail-id="<%= log_entry.id %>">
    <%= render "logs/log_entry_detail", log_entry: log_entry %>
  </div>
</div>
