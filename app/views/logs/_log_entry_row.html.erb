<%
  level_colors = {
    "trace" => "bg-gray-100 text-gray-700",
    "debug" => "bg-gray-100 text-gray-700",
    "info"  => "bg-blue-100 text-blue-700",
    "warn"  => "bg-yellow-100 text-yellow-800",
    "error" => "bg-red-100 text-red-800",
    "fatal" => "bg-red-200 text-red-900"
  }
  level_dot_colors = {
    "trace" => "bg-gray-400",
    "debug" => "bg-gray-400",
    "info"  => "bg-blue-400",
    "warn"  => "bg-yellow-400",
    "error" => "bg-red-400",
    "fatal" => "bg-red-600"
  }
  level = log_entry.level_name || "info"
%>

<tr class="hover:bg-gray-50 cursor-pointer"
    data-action="click->log-search#toggleDetail"
    data-log-entry-id="<%= log_entry.id %>">
  <td class="px-4 py-2">
    <div class="w-1.5 h-1.5 rounded-full <%= level_dot_colors[level] || 'bg-gray-400' %>"></div>
  </td>
  <td class="px-4 py-2 font-mono text-xs text-gray-500 whitespace-nowrap">
    <%= log_entry.occurred_at.strftime("%Y-%m-%d %H:%M:%S.%L") %>
  </td>
  <td class="px-4 py-2">
    <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-medium <%= level_colors[level] || 'bg-gray-100 text-gray-700' %>">
      <%= level.upcase %>
    </span>
  </td>
  <td class="px-4 py-2 font-mono text-xs text-gray-500 whitespace-nowrap">
    <%= log_entry.source %>
  </td>
  <td class="px-4 py-2 text-xs text-gray-900 font-mono max-w-md truncate">
    <%= log_entry.message %>
  </td>
  <td class="px-4 py-2 font-mono text-xs text-indigo-600 whitespace-nowrap">
    <%= log_entry.trace_id.present? ? log_entry.trace_id.truncate(12) : "" %>
  </td>
</tr>
<tr class="hidden" data-log-detail-id="<%= log_entry.id %>">
  <td colspan="6" class="px-6 py-4 border-l-4 border-indigo-200 bg-gray-50">
    <turbo-frame id="log_detail_<%= log_entry.id %>" src="<%= log_entry_path(log_entry) %>" loading="lazy">
      <div class="text-xs text-gray-400 py-2">Loading...</div>
    </turbo-frame>
  </td>
</tr>
