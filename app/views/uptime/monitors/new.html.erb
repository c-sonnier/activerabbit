<!-- Page Header -->
<div class="mb-8">
  <div>
    <h1 class="text-2xl font-bold text-gray-900">Add Uptime Monitor</h1>
    <p class="text-gray-600 mt-1">Monitor a URL for uptime, response time, and SSL certificate health</p>
  </div>
</div>

<!-- Main Content -->
<div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
  <!-- Form Section -->
  <div class="lg:col-span-2">
    <div class="bg-white rounded-lg shadow p-6">
      <h2 class="text-lg font-medium text-gray-900 mb-6">Monitor Configuration</h2>
      <%= render "form" %>
    </div>
  </div>

  <!-- Info Sidebar -->
  <div class="lg:col-span-1">
    <div class="bg-blue-50 border border-blue-200 rounded-lg p-6">
      <div class="flex">
        <div class="flex-shrink-0">
          <svg class="h-5 w-5 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
          </svg>
        </div>
        <div class="ml-3">
          <h3 class="text-sm font-medium text-blue-800">How it works</h3>
          <div class="mt-2 text-sm text-blue-700">
            <p>ActiveRabbit will ping your URL on the interval you set. You'll get alerts via Slack, Discord, or email when your service goes down or recovers.</p>
          </div>
        </div>
      </div>
    </div>

    <div class="bg-gray-100 rounded-xl p-6 mt-6 shadow-lg border border-gray-400">
      <h3 class="text-base font-semibold text-gray-900 mb-4">What we track</h3>
      <div class="space-y-3">
        <div class="flex items-start">
          <span class="flex-shrink-0 w-5 h-5 bg-green-500/20 rounded-full flex items-center justify-center mr-3 mt-0.5">
            <svg class="w-3 h-3 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path>
            </svg>
          </span>
          <p class="text-sm text-gray-600"><strong class="text-gray-900">Response time</strong> with DNS, connect, TLS, and TTFB breakdown</p>
        </div>
        <div class="flex items-start">
          <span class="flex-shrink-0 w-5 h-5 bg-green-500/20 rounded-full flex items-center justify-center mr-3 mt-0.5">
            <svg class="w-3 h-3 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path>
            </svg>
          </span>
          <p class="text-sm text-gray-600"><strong class="text-gray-900">SSL certificate</strong> expiry with 30/14/7 day warnings</p>
        </div>
        <div class="flex items-start">
          <span class="flex-shrink-0 w-5 h-5 bg-green-500/20 rounded-full flex items-center justify-center mr-3 mt-0.5">
            <svg class="w-3 h-3 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path>
            </svg>
          </span>
          <p class="text-sm text-gray-600"><strong class="text-gray-900">Uptime percentage</strong> with daily rollups and historical charts</p>
        </div>
        <div class="flex items-start">
          <span class="flex-shrink-0 w-5 h-5 bg-green-500/20 rounded-full flex items-center justify-center mr-3 mt-0.5">
            <svg class="w-3 h-3 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path>
            </svg>
          </span>
          <p class="text-sm text-gray-600"><strong class="text-gray-900">Instant alerts</strong> via Slack, Discord, and email on downtime</p>
        </div>
      </div>
    </div>
  </div>
</div>
