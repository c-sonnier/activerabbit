<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <!-- Header -->
  <div class="bg-white rounded-lg shadow mb-6">
    <div class="px-4 sm:px-6 py-4">
      <div class="flex flex-col sm:flex-row sm:justify-between sm:items-start gap-4">
        <div class="min-w-0">
          <h1 class="text-xl sm:text-2xl font-bold text-gray-900 truncate"><%= @monitor.name %></h1>
          <p class="text-gray-500 mt-1 text-sm truncate"><%= @monitor.url %></p>
          <div class="mt-3 flex flex-wrap items-center gap-2 sm:gap-3">
            <%
              badge_class = case @monitor.status
                            when "up" then "bg-green-100 text-green-800"
                            when "down" then "bg-red-100 text-red-800"
                            when "degraded" then "bg-yellow-100 text-yellow-800"
                            when "paused" then "bg-gray-100 text-gray-600"
                            else "bg-gray-100 text-gray-600"
                            end
            %>
            <span class="px-3 py-1 rounded-full text-sm font-medium <%= badge_class %>">
              <%= @monitor.status.upcase %>
            </span>
            <span class="inline-flex items-center text-xs sm:text-sm text-gray-500">
              <svg class="w-3.5 h-3.5 mr-1 text-gray-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
              </svg>
              <%= @recent_checks.first&.region || @monitor.region %>
            </span>
            <span class="text-xs sm:text-sm text-gray-500">
              Every <%= @monitor.interval_seconds / 60 %> min
            </span>
            <% if @monitor.last_checked_at %>
              <span class="text-xs sm:text-sm text-gray-500">
                Last checked <%= time_ago_in_words(@monitor.last_checked_at) %> ago
              </span>
            <% end %>
          </div>
        </div>
        <div class="flex flex-wrap items-center gap-2 shrink-0">
          <!-- Time Period Dropdown -->
          <%
            period_labels = { "1h" => "Last hour", "6h" => "Last 6 hours", "24h" => "Last 24 hours", "7d" => "Last 7 days", "30d" => "Last 30 days" }
            current_label = period_labels[@period] || "Last 24 hours"
          %>
          <div class="relative" data-controller="dropdown">
            <button data-action="click->dropdown#toggle" class="flex items-center gap-2 px-3 py-2 text-sm font-medium text-gray-700 bg-gray-50 border border-gray-300 rounded-lg hover:bg-gray-100 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500">
              <svg class="w-4 h-4 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              <span><%= current_label %></span>
              <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </button>
            <div data-dropdown-target="menu" class="hidden absolute right-0 mt-2 w-44 bg-white rounded-md shadow-lg ring-1 ring-black ring-opacity-5 z-50">
              <div class="py-1">
                <% period_labels.each do |key, label| %>
                  <%= link_to uptime_monitor_path(@monitor, period: key),
                      class: "block px-4 py-2 text-sm #{@period == key ? 'bg-indigo-50 text-indigo-700 font-medium' : 'text-gray-700 hover:bg-gray-100'}" do %>
                    <%= label %>
                  <% end %>
                <% end %>
              </div>
            </div>
          </div>

          <%= button_to "Check Now", check_now_uptime_monitor_path(@monitor), method: :post, class: "bg-white border border-gray-300 text-gray-700 px-3 py-2 rounded-lg hover:bg-gray-50 text-sm" %>
          <% if @monitor.paused? %>
            <%= button_to "Resume", resume_uptime_monitor_path(@monitor), method: :post, class: "bg-green-600 text-white px-3 py-2 rounded-lg hover:bg-green-700 text-sm" %>
          <% else %>
            <%= button_to "Pause", pause_uptime_monitor_path(@monitor), method: :post, class: "bg-yellow-500 text-white px-3 py-2 rounded-lg hover:bg-yellow-600 text-sm" %>
          <% end %>
          <%= link_to "Edit", edit_uptime_monitor_path(@monitor), class: "bg-white border border-gray-300 text-gray-700 px-3 py-2 rounded-lg hover:bg-gray-50 text-sm" %>
          <%= button_to "Delete", uptime_monitor_path(@monitor), method: :delete, data: { turbo_confirm: "Delete this monitor?" }, class: "bg-red-600 text-white px-3 py-2 rounded-lg hover:bg-red-700 text-sm" %>
        </div>
      </div>
    </div>
  </div>

  <!-- Metric Cards -->
  <div class="grid grid-cols-2 md:grid-cols-4 gap-3 sm:gap-4 mb-6">
    <div class="bg-white rounded-lg shadow p-3 sm:p-4">
      <p class="text-[10px] sm:text-xs text-gray-500 uppercase tracking-wide">Status</p>
      <p class="text-xl sm:text-2xl font-bold <%= @monitor.up? ? 'text-green-600' : 'text-red-600' %>"><%= @monitor.status.upcase %></p>
    </div>
    <div class="bg-white rounded-lg shadow p-3 sm:p-4">
      <p class="text-[10px] sm:text-xs text-gray-500 uppercase tracking-wide">Uptime (30d)</p>
      <p class="text-xl sm:text-2xl font-bold text-gray-900"><%= @uptime_30d ? "#{@uptime_30d}%" : "—" %></p>
    </div>
    <div class="bg-white rounded-lg shadow p-3 sm:p-4">
      <p class="text-[10px] sm:text-xs text-gray-500 uppercase tracking-wide">Avg Response</p>
      <p class="text-xl sm:text-2xl font-bold text-gray-900"><%= @avg_response ? "#{@avg_response.round}ms" : "—" %></p>
    </div>
    <div class="bg-white rounded-lg shadow p-3 sm:p-4">
      <p class="text-[10px] sm:text-xs text-gray-500 uppercase tracking-wide">SSL Expires</p>
      <% if @monitor.ssl_expiry %>
        <% days = (@monitor.ssl_expiry.to_date - Date.current).to_i %>
        <p class="text-xl sm:text-2xl font-bold <%= days < 14 ? 'text-red-600' : 'text-gray-900' %>"><%= days %> days</p>
      <% else %>
        <p class="text-xl sm:text-2xl font-bold text-gray-400">—</p>
      <% end %>
    </div>
  </div>

  <!-- Response Time Chart -->
  <div class="bg-white rounded-lg shadow p-4 sm:p-6 mb-6 overflow-hidden"
       data-controller="uptime-chart"
       data-uptime-chart-data-value="<%= @chart_checks.map { |c| { t: c[0].iso8601, ms: c[1], ok: c[2] } }.to_json %>">
    <% chart_label = { "1h" => "1h", "6h" => "6h", "24h" => "24h", "7d" => "7d", "30d" => "30d" }[@period] || "24h" %>
    <h2 class="text-base sm:text-lg font-semibold text-gray-900 mb-4">Response Time (<%= chart_label %>)</h2>
    <div class="w-full" style="position: relative; height: 200px;">
      <canvas data-uptime-chart-target="canvas"></canvas>
      <div data-uptime-chart-target="tooltip"
           class="absolute bg-white border border-gray-200 rounded-lg shadow-lg px-3 py-2 pointer-events-none z-10"
           style="display: none; min-width: 120px;"></div>
    </div>

    <!-- Uptime Status Bar -->
    <div class="mt-4 pt-3 border-t border-gray-100">
      <div class="flex items-center justify-between mb-2">
        <span class="text-xs text-gray-500">Uptime (<%= chart_label %>)</span>
        <div class="flex items-center gap-3 text-xs text-gray-400">
          <span class="flex items-center gap-1"><span class="inline-block w-2 h-2 rounded-sm bg-green-500"></span> Up</span>
          <span class="flex items-center gap-1"><span class="inline-block w-2 h-2 rounded-sm bg-yellow-500"></span> Degraded</span>
          <span class="flex items-center gap-1"><span class="inline-block w-2 h-2 rounded-sm bg-red-500"></span> Down</span>
        </div>
      </div>
      <div style="position: relative;">
        <div data-uptime-chart-target="statusBar"
             class="w-full flex items-end"
             style="height: 28px;"></div>
        <div data-uptime-chart-target="barTooltip"
             class="absolute bg-gray-900 text-white rounded-lg shadow-lg px-3 py-2 pointer-events-none z-20 text-xs"
             style="display: none; min-width: 150px; bottom: 36px;"></div>
      </div>
    </div>
  </div>

  <!-- Recent Checks -->
  <div class="bg-white rounded-lg shadow overflow-hidden">
    <div class="px-4 sm:px-6 py-4 border-b border-gray-200">
      <h2 class="text-base sm:text-lg font-semibold text-gray-900">Recent Checks</h2>
    </div>
    <div class="overflow-x-auto">
      <table class="w-full min-w-[700px]">
        <thead>
          <tr class="bg-gray-50 border-b border-gray-200">
            <th class="px-3 sm:px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Time</th>
            <th class="px-3 sm:px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Status</th>
            <th class="px-3 sm:px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Response</th>
            <th class="px-3 sm:px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">DNS</th>
            <th class="px-3 sm:px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Connect</th>
            <th class="px-3 sm:px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">TLS</th>
            <th class="px-3 sm:px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">TTFB</th>
            <th class="px-3 sm:px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Error</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          <% @recent_checks.each do |check| %>
            <tr class="hover:bg-gray-50">
              <td class="px-3 sm:px-6 py-3 text-sm text-gray-500 whitespace-nowrap"><%= check.created_at.strftime("%b %d, %H:%M:%S") %></td>
              <td class="px-3 sm:px-6 py-3">
                <span class="px-2 py-1 rounded-full text-xs font-medium <%= check.success ? 'bg-green-100 text-green-800' : 'bg-red-100 text-red-800' %>">
                  <%= check.status_code || "ERR" %>
                </span>
              </td>
              <td class="px-3 sm:px-6 py-3 text-sm text-gray-700 whitespace-nowrap"><%= check.response_time_ms ? "#{check.response_time_ms}ms" : "—" %></td>
              <td class="px-3 sm:px-6 py-3 text-sm text-gray-500 whitespace-nowrap"><%= check.dns_time_ms ? "#{check.dns_time_ms}ms" : "—" %></td>
              <td class="px-3 sm:px-6 py-3 text-sm text-gray-500 whitespace-nowrap"><%= check.connect_time_ms ? "#{check.connect_time_ms}ms" : "—" %></td>
              <td class="px-3 sm:px-6 py-3 text-sm text-gray-500 whitespace-nowrap"><%= check.tls_time_ms ? "#{check.tls_time_ms}ms" : "—" %></td>
              <td class="px-3 sm:px-6 py-3 text-sm text-gray-500 whitespace-nowrap"><%= check.ttfb_ms ? "#{check.ttfb_ms}ms" : "—" %></td>
              <td class="px-3 sm:px-6 py-3 text-sm text-red-500 max-w-[150px] truncate"><%= check.error_message if check.error_message %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <!-- Pagination -->
    <div class="px-4 sm:px-6 py-4 border-t border-gray-200">
      <%= render "shared/pagination_prev_next", pagy: @pagy %>
    </div>
  </div>

  <!-- Data Retention Info -->
  <div class="mt-4 flex flex-wrap items-center justify-center gap-1 sm:gap-2 text-xs sm:text-sm text-gray-400 text-center">
    <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
    </svg>
    <span>Check data is retained for <strong class="text-gray-500"><%= @retention_days %> days</strong> on your current plan.
    <% if @retention_days < 31 %>
      <%= link_to "Upgrade for 31-day retention", plan_path, class: "text-indigo-500 hover:text-indigo-700 underline" %>.
    <% end %>
    </span>
  </div>
</div>
