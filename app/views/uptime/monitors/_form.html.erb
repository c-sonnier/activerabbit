<%= form_with(model: @monitor, url: @monitor.persisted? ? uptime_monitor_path(@monitor) : uptime_monitors_path, local: true, class: "space-y-6") do |form| %>

  <% if flash[:alert].present? %>
    <div class="bg-yellow-50 border border-yellow-200 rounded-lg p-4">
      <div class="flex">
        <div class="flex-shrink-0">
          <svg class="h-5 w-5 text-yellow-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L3.268 16.5c-.77.833.192 2.5 1.732 2.5z"></path>
          </svg>
        </div>
        <div class="ml-3">
          <h3 class="text-sm font-medium text-yellow-800"><%= flash[:alert] %></h3>
          <div class="mt-2">
            <%= link_to "View Plans", plan_path, class: "text-sm font-medium text-yellow-700 underline hover:text-yellow-800" %>
          </div>
        </div>
      </div>
    </div>
  <% end %>

  <% if @monitor.errors.any? %>
    <div class="bg-red-50 border border-red-200 rounded-lg p-4">
      <div class="flex">
        <div class="flex-shrink-0">
          <svg class="h-5 w-5 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L3.268 16.5c-.77.833.192 2.5 1.732 2.5z"></path>
          </svg>
        </div>
        <div class="ml-3">
          <h3 class="text-sm font-medium text-red-800">
            There were <%= pluralize(@monitor.errors.count, "error") %> with your submission:
          </h3>
          <div class="mt-2 text-sm text-red-700">
            <ul class="list-disc pl-5 space-y-1">
              <% @monitor.errors.full_messages.each do |msg| %>
                <li><%= msg %></li>
              <% end %>
            </ul>
          </div>
        </div>
      </div>
    </div>
  <% end %>

  <!-- URL -->
  <div>
    <%= form.label :url, "URL to Monitor", class: "block text-sm font-medium text-gray-700 mb-2" %>
    <div class="relative">
      <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
        <svg class="h-5 w-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"></path>
        </svg>
      </div>
      <%= form.url_field :url, placeholder: "https://example.com/health", required: true, class: "appearance-none block w-full pl-10 pr-3 py-3 border border-gray-300 placeholder-gray-400 text-gray-900 rounded-xl shadow-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition-all duration-200 sm:text-sm" %>
    </div>
    <p class="mt-1 text-xs text-gray-500">The endpoint to check — use a health check or status URL for best results</p>
    <% if @monitor.errors[:url].any? %>
      <p class="mt-1 text-sm text-red-600"><%= @monitor.errors[:url].first %></p>
    <% end %>
  </div>

  <!-- Name -->
  <div>
    <%= form.label :name, "Monitor Name", class: "block text-sm font-medium text-gray-700 mb-2" %>
    <%= form.text_field :name, placeholder: "Production API", required: true, class: "appearance-none block w-full px-3 py-3 border border-gray-300 placeholder-gray-400 text-gray-900 rounded-xl shadow-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition-all duration-200 sm:text-sm" %>
    <p class="mt-1 text-xs text-gray-500">A friendly name to identify this monitor in alerts and dashboards</p>
    <% if @monitor.errors[:name].any? %>
      <p class="mt-1 text-sm text-red-600"><%= @monitor.errors[:name].first %></p>
    <% end %>
  </div>

  <!-- Check Settings -->
  <div>
    <h3 class="text-sm font-medium text-gray-900 mb-3">Check Settings</h3>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      <div>
        <%= form.label :interval_seconds, "Check Interval", class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= form.select :interval_seconds, [["Every 1 min", 60], ["Every 5 min", 300], ["Every 10 min", 600]], {}, class: "appearance-none block w-full px-3 py-3 border border-gray-300 text-gray-900 rounded-xl shadow-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition-all duration-200 sm:text-sm" %>
      </div>

      <div>
        <%= form.label :http_method, "HTTP Method", class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= form.select :http_method, ["GET", "HEAD", "POST"], {}, class: "appearance-none block w-full px-3 py-3 border border-gray-300 text-gray-900 rounded-xl shadow-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition-all duration-200 sm:text-sm" %>
      </div>

      <div>
        <%= form.label :expected_status_code, "Expected Status", class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= form.number_field :expected_status_code, class: "appearance-none block w-full px-3 py-3 border border-gray-300 text-gray-900 rounded-xl shadow-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition-all duration-200 sm:text-sm" %>
        <p class="mt-1 text-xs text-gray-500">Default: 200</p>
      </div>
    </div>
  </div>

  <!-- Alert Settings -->
  <div>
    <h3 class="text-sm font-medium text-gray-900 mb-3">Alert Settings</h3>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div>
        <%= form.label :timeout_seconds, "Timeout", class: "block text-sm font-medium text-gray-700 mb-2" %>
        <div class="relative">
          <%= form.number_field :timeout_seconds, min: 1, max: 60, class: "appearance-none block w-full px-3 py-3 pr-16 border border-gray-300 text-gray-900 rounded-xl shadow-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition-all duration-200 sm:text-sm" %>
          <div class="absolute inset-y-0 right-0 pr-3 flex items-center pointer-events-none">
            <span class="text-gray-400 text-sm">seconds</span>
          </div>
        </div>
        <p class="mt-1 text-xs text-gray-500">How long to wait before marking a check as failed</p>
      </div>

      <div>
        <%= form.label :alert_threshold, "Alert Threshold", class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= form.select :alert_threshold, [["After 1 failure", 1], ["After 2 failures", 2], ["After 3 failures", 3], ["After 5 failures", 5]], {}, class: "appearance-none block w-full px-3 py-3 border border-gray-300 text-gray-900 rounded-xl shadow-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition-all duration-200 sm:text-sm" %>
        <p class="mt-1 text-xs text-gray-500">Consecutive failures before sending a down alert</p>
      </div>
    </div>
  </div>

  <!-- Actions -->
  <div class="flex items-center justify-between pt-6 border-t border-gray-200">
    <%= link_to uptime_index_path, class: "text-sm text-gray-500 hover:text-gray-700" do %>
      &larr; Back to monitors
    <% end %>

    <%= form.submit @monitor.persisted? ? "Update Monitor" : "Create Monitor & Start Checking",
        class: "inline-flex items-center px-6 py-3 border border-transparent text-sm font-medium rounded-xl shadow-sm text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 transition-all duration-200 cursor-pointer" %>
  </div>
<% end %>
